---
---
<section id="section-offer" class="section-dark section-pad offer-section" style="background:#0C1222;border-top:1px solid rgba(29,95,191,0.15);">
  <div class="offer-inner">

    <!-- ==============================
         EN-TÊTE CENTRÉ — pleine largeur
         ============================== -->
    <div class="offer-header gs-hidden" data-gs="s8" data-gs-delay="0">
      <div class="badge-pill offer-badge" style="background:rgba(59,130,246,0.12);border-color:rgba(96,165,250,0.28);">
        <span class="dot"></span>
        <span style="color:#93C5FD;font-weight:500;">
          <span id="founder-count" style="color:#FFFFFF;font-weight:700;">—</span> / 100 entreprises fondatrices
        </span>
      </div>
      <h2 class="offer-title">
        Les 100 premi&egrave;res entreprises<br>b&eacute;n&eacute;ficient de conditions exclusives
      </h2>
      <p class="offer-subtitle">
        Cette premi&egrave;re phase est limit&eacute;e pour accompagner chaque d&eacute;ploiement dans les meilleures conditions.
      </p>
    </div>

    <!-- ==============================
         FORMULAIRE CENTRÉ
         ============================== -->
    <div class="offer-form-wrapper">
        <div id="section-callback" class="offer-form-card gs-hidden" data-gs="s8" data-gs-delay="0.12">

          <div id="offer-form-container">
            <div style="text-align:center;margin-bottom:22px;">
              <div class="badge-pill" style="margin:0 auto 14px auto;background:rgba(29,95,191,0.08);border-color:rgba(29,95,191,0.22);">
                <span class="dot" style="background:#1D5FBF;"></span>
                <span style="color:#1D5FBF;font-weight:500;"><span id="founder-count2" style="color:#111827;font-weight:700;">—</span> / 100 entreprises fondatrices</span>
              </div>
              <h3 class="form-title">Rejoindre les entreprises fondatrices</h3>
              <p class="form-subtitle">Les 100 premi&egrave;res acc&egrave;dent &agrave; l'offre exclusive avant son ouverture publique.</p>
            </div>

            <div class="form-qualification">
              <span style="font-size:17px;flex-shrink:0;">&#128222;</span>
              <span>Appel de qualification de <strong>15 minutes</strong> pour valider votre acc&egrave;s.</span>
            </div>

            <!-- Honeypot anti-spam — ne pas remplir -->
            <input type="text" id="offer-trap" name="_trap" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;pointer-events:none;" />

            <div class="form-fields">
              <div class="form-row">
                <div>
                  <label class="form-label">Pr&eacute;nom <span class="form-required">*</span></label>
                  <input type="text" class="form-input" id="offer-prenom" placeholder="Votre pr&eacute;nom" required>
                </div>
                <div>
                  <label class="form-label">Nom <span class="form-required">*</span></label>
                  <input type="text" class="form-input" id="offer-nom" placeholder="Votre nom" required>
                </div>
              </div>
              <div>
                <label class="form-label">Soci&eacute;t&eacute; <span class="form-required">*</span></label>
                <input type="text" class="form-input" id="offer-societe" placeholder="Nom de votre soci&eacute;t&eacute;" required>
              </div>
              <div>
                <label class="form-label">E-mail professionnel <span class="form-required">*</span></label>
                <input type="email" class="form-input" id="offer-email" placeholder="votre@entreprise.com" required>
              </div>
              <div>
                <label class="form-label">T&eacute;l&eacute;phone <span class="form-required">*</span></label>
                <input type="tel" class="form-input" id="offer-tel" placeholder="06 00 00 00 00" required>
              </div>
              <div>
                <label class="form-checkbox-label">
                  <input type="checkbox" id="offer-consent" required class="form-checkbox">
                  <span>J'accepte d'&ecirc;tre contact&eacute; par t&eacute;l&eacute;phone. <span class="form-required">*</span></span>
                </label>
              </div>
              <button class="form-submit" onclick="submitOfferForm()">Demander sa place &rarr;</button>
              <div style="text-align:center;font-size:13px;color:#111827;margin-top:8px;">Pr&eacute;ventes ouvertes jusqu'au <strong style="color:#111827;">17/04/26</strong></div>
              <div class="form-reassurance">
                <div><span class="form-check">&#10003;</span><span>Aucun engagement.</span></div>
                <div><span class="form-check">&#10003;</span><span>Nous v&eacute;rifions si le syst&egrave;me correspond &agrave; votre activit&eacute;.</span></div>
              </div>
              <p class="form-cal">
                Vous pr&eacute;f&eacute;rez r&eacute;server directement un &eacute;change&nbsp;?<br>
                <a href="https://cal.com/a.seingier-virtuodev/15min" target="_blank" rel="noopener">Acc&eacute;dez &agrave; notre calendrier</a>
              </p>
            </div>
          </div>

        </div>
    </div><!-- /offer-form-wrapper -->
  </div>
</section>

<style>
  /* ================================
     CONTENEUR LARGE
     ================================ */
  .offer-section {
    padding-left: 0;
    padding-right: 0;
  }

  .offer-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  /* ================================
     EN-TÊTE CENTRÉ
     ================================ */
  .offer-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .offer-badge {
    margin: 0 auto 24px auto;
    display: inline-flex;
  }

  .offer-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(30px, 3.8vw, 52px);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    margin: 0 auto 20px auto;
    max-width: 720px;
  }

  .offer-subtitle {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 19px);
    color: #FFFFFF;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ================================
     FORMULAIRE CENTRÉ
     ================================ */
  .offer-form-wrapper {
    display: flex;
    justify-content: center;
  }

  /* ================================
     FORMULAIRE
     ================================ */
  .offer-form-card {
    background: #FFFFFF;
    border: 1px solid rgba(229,231,235,1);
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.3), 0 4px 20px rgba(0,0,0,0.12);
    width: 100%;
    max-width: 520px;
  }

  .form-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(29,95,191,0.1);
    border: 1px solid rgba(29,95,191,0.25);
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 600;
    color: #1D5FBF;
    letter-spacing: 0.02em;
  }

  .form-badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #1D5FBF;
    flex-shrink: 0;
  }

  .form-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(17px, 1.6vw, 20px);
    color: #111827;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0 0 8px 0;
  }

  .form-subtitle {
    font-size: 13px;
    color: #6B7280;
    line-height: 1.55;
    margin: 0;
  }

  .form-qualification {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(29,95,191,0.06);
    border: 1px solid rgba(29,95,191,0.15);
    border-radius: 10px;
    padding: 11px 14px;
    margin-bottom: 20px;
    font-size: 13px;
    color: #374151;
    line-height: 1.5;
  }

  .form-qualification strong { color: #111827; }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  /* Prénom + Nom côte à côte */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .form-label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: #374151;
    margin-bottom: 5px;
  }

  .form-required { color: #ef4444; }

  .form-input {
    width: 100%;
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 14px;
    color: #111827;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .form-input:focus {
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    background: #FFFFFF;
  }

  .form-checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
    font-size: 13px;
    color: #4B5563;
    line-height: 1.5;
  }

  .form-checkbox {
    margin-top: 3px;
    accent-color: #3B82F6;
    flex-shrink: 0;
  }

  .form-submit {
    width: 100%;
    background: #1D5FBF;
    color: #FFFFFF;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    padding: 14px 20px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(29,95,191,0.35);
    transition: background 0.2s ease, transform 0.15s ease;
    margin-top: 2px;
  }

  .form-submit:hover {
    background: #174EA6;
    transform: translateY(-1px);
  }

  .form-reassurance {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .form-reassurance div {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #6B7280;
  }

  .form-check {
    color: #16A34A;
    font-size: 12px;
    flex-shrink: 0;
  }

  .form-cal {
    font-size: 14px;
    color: #111827;
    text-align: center;
    line-height: 1.7;
    margin: 8px 0 0 0;
    padding: 14px 16px;
    background: rgba(29,95,191,0.04);
    border: 1px solid rgba(29,95,191,0.12);
    border-radius: 10px;
  }

  .form-cal a {
    display: inline-block;
    margin-top: 6px;
    color: #1D5FBF;
    font-weight: 600;
    font-size: 15px;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .form-cal a:hover { color: #174EA6; }

  /* ================================
     RESPONSIVE
     ================================ */
  @media (max-width: 1024px) {
    .offer-inner { padding: 64px 32px; }
  }

  @media (max-width: 860px) {
    .offer-inner { padding: 56px 20px; }

    .offer-header { margin-bottom: 48px; }

    .offer-form-card { padding: 28px 22px; }

    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 520px) {
    .offer-title { font-size: 36px; }
  }
</style>

<script>
  // ========================================
  // OFFER FORM
  // ========================================
  function getUTMParams() {
    const p = new URLSearchParams(window.location.search);
    return {
      utm_source:   p.get('utm_source')   ?? '',
      utm_medium:   p.get('utm_medium')   ?? '',
      utm_campaign: p.get('utm_campaign') ?? '',
    };
  }

  function detectSource() {
    const utm = new URLSearchParams(window.location.search).get('utm_source');
    if (utm) return utm;
    const ref = document.referrer;
    if (!ref) return 'direct';
    try { return new URL(ref).hostname; } catch { return 'direct'; }
  }

  async function submitOfferForm() {
    const prenom  = document.getElementById('offer-prenom').value.trim();
    const nom     = document.getElementById('offer-nom').value.trim();
    const societe = document.getElementById('offer-societe').value.trim();
    const email   = document.getElementById('offer-email').value.trim();
    const tel     = document.getElementById('offer-tel').value.trim();
    const consent = document.getElementById('offer-consent').checked;
    const trap    = document.getElementById('offer-trap').value;
    let hasError  = false;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const telRegex   = /^(\+33|0)[0-9](\s?\d{2}){4}$/;

    // Réinitialiser les erreurs visuelles
    document.querySelectorAll('.form-input').forEach(i => { i.style.borderColor = ''; });
    const consentLabel = document.getElementById('offer-consent').closest('label');
    consentLabel.style.color = '';

    if (!prenom)  { document.getElementById('offer-prenom').style.borderColor  = '#ef4444'; hasError = true; }
    if (!nom)     { document.getElementById('offer-nom').style.borderColor     = '#ef4444'; hasError = true; }
    if (!societe) { document.getElementById('offer-societe').style.borderColor = '#ef4444'; hasError = true; }
    if (!email || !emailRegex.test(email)) { document.getElementById('offer-email').style.borderColor = '#ef4444'; hasError = true; }
    if (!tel || !telRegex.test(tel.replace(/\s/g, ''))) { document.getElementById('offer-tel').style.borderColor = '#ef4444'; hasError = true; }
    if (!consent) { consentLabel.style.color = '#ef4444'; hasError = true; }
    if (hasError) return;

    const btn = document.querySelector('.form-submit');
    btn.disabled = true;
    btn.textContent = 'Envoi en cours\u2026';

    // Supprimer l'erreur précédente si elle existe
    const existingErr = document.getElementById('form-submit-error');
    if (existingErr) existingErr.remove();

    try {
      const utm = getUTMParams();
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prenom, nom, societe, email, tel, _trap: trap, source: detectSource(), ...utm }),
      });

      if (res.ok) {
        window.location.href = '/merci';
      } else {
        const data = await res.json().catch(() => ({}));
        btn.disabled = false;
        btn.textContent = 'Demander sa place \u2192';
        const errEl = document.createElement('p');
        errEl.id = 'form-submit-error';
        errEl.style.cssText = 'color:#ef4444;font-size:13px;text-align:center;margin:8px 0 0;';
        errEl.textContent = data.error || 'Une erreur est survenue. R\u00e9essayez.';
        btn.insertAdjacentElement('afterend', errEl);
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Demander sa place \u2192';
      const errEl = document.createElement('p');
      errEl.id = 'form-submit-error';
      errEl.style.cssText = 'color:#ef4444;font-size:13px;text-align:center;margin:8px 0 0;';
      errEl.textContent = 'Erreur r\u00e9seau. V\u00e9rifiez votre connexion.';
      btn.insertAdjacentElement('afterend', errEl);
    }
  }

  document.querySelectorAll('.form-input').forEach(input => {
    input.addEventListener('focus', () => { input.style.borderColor = ''; });
  });

  // Réinitialiser la couleur du label consent quand la checkbox change
  document.getElementById('offer-consent').addEventListener('change', function() {
    this.closest('label').style.color = '';
  });

  window.submitOfferForm = submitOfferForm;

  // ========================================
  // COMPTEUR ENTREPRISES FONDATRICES
  // ========================================
  const FOUNDERS_API_URL = '/api/count';

  async function loadFounderCount() {
    if (!FOUNDERS_API_URL) return;
    try {
      const res   = await fetch(FOUNDERS_API_URL);
      if (!res.ok) return;
      const data  = await res.json();
      const count = data.count ?? data.length ?? data;
      if (typeof count === 'number') {
        const el  = document.getElementById('founder-count');
        const el2 = document.getElementById('founder-count2');
        if (el)  { el.textContent  = String(count); }
        if (el2) { el2.textContent = String(count); el2.style.color = '#111827'; }
      }
    } catch (e) { /* silently fail */ }
  }

  loadFounderCount();
</script>
