---
import Confirmation from './Confirmation.astro';
---
<section id="section-offer" class="section-dark section-pad offer-section" style="background:#0C1222;border-top:1px solid rgba(29,95,191,0.15);">
  <div class="offer-inner">

    <!-- ==============================
         EN-TÊTE CENTRÉ — pleine largeur
         ============================== -->
    <div class="offer-header gs-hidden" data-gs="s8" data-gs-delay="0">
      <div class="badge-pill offer-badge" style="background:rgba(59,130,246,0.12);border-color:rgba(96,165,250,0.28);">
        <span class="dot"></span>
        <span style="color:#93C5FD;font-weight:500;">
          <span id="founder-count" style="color:#FFFFFF;font-weight:700;">3</span> / 100 entreprises fondatrices
        </span>
      </div>
      <h2 class="offer-title">
        Les 100 premi&egrave;res entreprises<br>b&eacute;n&eacute;ficient de conditions exclusives
      </h2>
      <p class="offer-subtitle">
        Cette premi&egrave;re phase est limit&eacute;e pour accompagner chaque d&eacute;ploiement dans les meilleures conditions.
      </p>
    </div>

    <!-- ==============================
         GRILLE 60 / 40
         ============================== -->
    <div class="offer-layout">

      <!-- COLONNE GAUCHE — contenu -->
      <div class="offer-left">

        <div class="gs-hidden offer-cards-label" data-gs="s8" data-gs-delay="0.1">
          Ce que comprend l&rsquo;offre fondatrice
        </div>

        <!-- Carte principale -->
        <div class="gs-hidden founder-card-main" data-gs="s8" data-gs-delay="0.15">
          <div class="founder-card-label">Acc&egrave;s</div>
          <div class="founder-card-divider"></div>
          <div class="founder-card-title">365 jours d&rsquo;acc&egrave;s</div>
          <p class="founder-card-text">Les entreprises fondatrices b&eacute;n&eacute;ficient du syst&egrave;me pendant 1 an.</p>
        </div>

        <!-- Cartes secondaires -->
        <div class="gs-hidden founder-secondary-grid" data-gs="s8" data-gs-delay="0.2">
          <div class="founder-card-secondary">
            <div class="founder-card-label">Visibilit&eacute;</div>
            <div class="founder-card-divider"></div>
            <div class="founder-card-title">Du contenu pour votre visibilit&eacute;</div>
            <p class="founder-card-text">Contenus et publications pour alimenter vos r&eacute;seaux sociaux.</p>
          </div>
          <div class="founder-card-secondary">
            <div class="founder-card-label">Analyse</div>
            <div class="founder-card-divider"></div>
            <div class="founder-card-title">Un bilan commercial complet</div>
            <p class="founder-card-text">Devis, fid&eacute;lisation, suivi&nbsp;: une analyse compl&egrave;te transmise.</p>
          </div>
        </div>

        <!-- Bloc bonus -->
        <div class="gs-hidden offer-bonus" data-gs="s8" data-gs-delay="0.25">
          <p class="offer-bonus-title">Bonus entreprises fondatrices</p>
          <p class="offer-bonus-text">
            Vos anciens devis de <strong style="color:#FFFFFF;font-weight:600;">0 &agrave; 2 ans</strong> seront relanc&eacute;s gratuitement avec une s&eacute;quence personnalis&eacute;e.
          </p>
        </div>

      </div><!-- /offer-left -->


      <!-- COLONNE DROITE — formulaire -->
      <div class="offer-right">
        <div id="section-callback" class="offer-form-card gs-hidden" data-gs="s8" data-gs-delay="0.12">

          <div id="offer-form-container">
            <div style="text-align:center;margin-bottom:22px;">
              <div class="badge-pill" style="margin:0 auto 14px auto;background:rgba(29,95,191,0.08);border-color:rgba(29,95,191,0.22);">
                <span class="dot" style="background:#1D5FBF;"></span>
                <span style="color:#1D5FBF;font-weight:500;"><span id="founder-count2" style="color:#111827;font-weight:700;">—</span> / 100 entreprises fondatrices</span>
              </div>
              <h3 class="form-title">Rejoindre les entreprises fondatrices</h3>
              <p class="form-subtitle">Les 100 premi&egrave;res acc&egrave;dent &agrave; l'offre exclusive avant son ouverture publique.</p>
            </div>

            <div class="form-qualification">
              <span style="font-size:17px;flex-shrink:0;">&#128222;</span>
              <span>Appel de qualification de <strong>15 minutes</strong> pour valider votre acc&egrave;s.</span>
            </div>

            <div class="form-fields">
              <div class="form-row">
                <div>
                  <label class="form-label">Pr&eacute;nom <span class="form-required">*</span></label>
                  <input type="text" class="form-input" id="offer-prenom" placeholder="Votre pr&eacute;nom" required>
                </div>
                <div>
                  <label class="form-label">Nom <span class="form-required">*</span></label>
                  <input type="text" class="form-input" id="offer-nom" placeholder="Votre nom" required>
                </div>
              </div>
              <div>
                <label class="form-label">Soci&eacute;t&eacute; <span class="form-required">*</span></label>
                <input type="text" class="form-input" id="offer-societe" placeholder="Nom de votre soci&eacute;t&eacute;" required>
              </div>
              <div>
                <label class="form-label">E-mail professionnel <span class="form-required">*</span></label>
                <input type="email" class="form-input" id="offer-email" placeholder="votre@entreprise.com" required>
              </div>
              <div>
                <label class="form-label">T&eacute;l&eacute;phone <span class="form-required">*</span></label>
                <input type="tel" class="form-input" id="offer-tel" placeholder="06 00 00 00 00" required>
              </div>
              <div>
                <label class="form-checkbox-label">
                  <input type="checkbox" id="offer-consent" required class="form-checkbox">
                  <span>J'accepte d'&ecirc;tre contact&eacute; par t&eacute;l&eacute;phone. <span class="form-required">*</span></span>
                </label>
              </div>
              <button class="form-submit" onclick="submitOfferForm()">Demander sa place &rarr;</button>
              <div class="form-reassurance">
                <div><span class="form-check">&#10003;</span><span>Aucun engagement.</span></div>
                <div><span class="form-check">&#10003;</span><span>Nous v&eacute;rifions si le syst&egrave;me correspond &agrave; votre activit&eacute;.</span></div>
              </div>
              <p class="form-cal">
                Vous pr&eacute;f&eacute;rez r&eacute;server directement un &eacute;change&nbsp;?<br>
                <a href="https://cal.com/a.seingier-virtuodev/15min" target="_blank" rel="noopener">Acc&eacute;dez &agrave; notre calendrier</a>
              </p>
            </div>
          </div>

          <Confirmation />

        </div>
      </div><!-- /offer-right -->

    </div><!-- /offer-layout -->
  </div>
</section>

<style>
  /* ================================
     CONTENEUR LARGE
     ================================ */
  .offer-section {
    padding-left: 0;
    padding-right: 0;
  }

  .offer-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 80px 48px;
  }

  /* ================================
     EN-TÊTE CENTRÉ
     ================================ */
  .offer-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .offer-badge {
    margin: 0 auto 24px auto;
    display: inline-flex;
  }

  .offer-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(30px, 3.8vw, 52px);
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #FFFFFF;
    margin: 0 auto 20px auto;
    max-width: 720px;
  }

  .offer-subtitle {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 19px);
    color: #FFFFFF;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ================================
     GRILLE 60 / 40
     ================================ */
  .offer-layout {
    display: grid;
    grid-template-columns: 60fr 40fr;
    gap: 96px;
    align-items: start;
  }

  .offer-right {
    position: sticky;
    top: 88px;
  }

  /* ================================
     COLONNE GAUCHE — cartes
     ================================ */
  .offer-cards-label {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 34px);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-transform: none;
    color: #93C5FD;
    margin-bottom: 28px;
    margin-top: 48px;
    text-align: center;
  }

  .founder-card-main {
    background: linear-gradient(160deg, #0D1829 0%, #0A1020 100%);
    border: 1px solid rgba(96,165,250,0.3);
    border-top: 1px solid rgba(96,165,250,0.6);
    border-radius: 18px;
    padding: 32px;
    box-shadow: 0 20px 50px rgba(2,6,23,0.4), inset 0 1px 0 rgba(96,165,250,0.12);
    text-align: center;
  }

  .founder-secondary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-top: 14px;
  }

  .founder-card-secondary {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.09);
    border-top: 1px solid rgba(255,255,255,0.18);
    border-radius: 18px;
    padding: 24px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-align: center;
  }
  .founder-card-secondary:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .founder-card-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #93C5FD;
    opacity: 0.85;
  }

  .founder-card-divider {
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,0.15);
    margin: 14px auto;
  }

  .founder-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(18px, 1.6vw, 22px);
    color: #FFFFFF;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .founder-card-text {
    font-family: var(--font-body);
    font-size: 15px;
    color: #FFFFFF;
    margin-top: 10px;
    line-height: 1.7;
  }

  .offer-bonus {
    margin-top: 18px;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(96,165,250,0.22);
    border-top: 1px solid rgba(96,165,250,0.5);
    border-radius: 18px;
    padding: 28px 32px;
    box-shadow: inset 0 1px 0 rgba(96,165,250,0.1);
    text-align: center;
  }

  .offer-bonus-title {
    font-family: var(--font-display);
    font-size: clamp(19px, 1.8vw, 24px);
    font-weight: 800;
    color: #FFFFFF;
    letter-spacing: -0.02em;
    margin-bottom: 10px;
  }

  .offer-bonus-text {
    font-family: var(--font-body);
    font-size: 16px;
    color: #FFFFFF;
    line-height: 1.7;
  }

  /* ================================
     COLONNE DROITE — formulaire
     ================================ */
  .offer-form-card {
    background: #FFFFFF;
    border: 1px solid rgba(229,231,235,1);
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.3), 0 4px 20px rgba(0,0,0,0.12);
  }

  .form-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(29,95,191,0.1);
    border: 1px solid rgba(29,95,191,0.25);
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 14px;
    font-size: 12px;
    font-weight: 600;
    color: #1D5FBF;
    letter-spacing: 0.02em;
  }

  .form-badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #1D5FBF;
    flex-shrink: 0;
  }

  .form-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(17px, 1.6vw, 20px);
    color: #111827;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin: 0 0 8px 0;
  }

  .form-subtitle {
    font-size: 13px;
    color: #6B7280;
    line-height: 1.55;
    margin: 0;
  }

  .form-qualification {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(29,95,191,0.06);
    border: 1px solid rgba(29,95,191,0.15);
    border-radius: 10px;
    padding: 11px 14px;
    margin-bottom: 20px;
    font-size: 13px;
    color: #374151;
    line-height: 1.5;
  }

  .form-qualification strong { color: #111827; }

  .form-fields {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  /* Prénom + Nom côte à côte */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .form-label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    color: #374151;
    margin-bottom: 5px;
  }

  .form-required { color: #ef4444; }

  .form-input {
    width: 100%;
    background: #F9FAFB;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 14px;
    color: #111827;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .form-input:focus {
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    background: #FFFFFF;
  }

  .form-checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    cursor: pointer;
    font-size: 13px;
    color: #4B5563;
    line-height: 1.5;
  }

  .form-checkbox {
    margin-top: 3px;
    accent-color: #3B82F6;
    flex-shrink: 0;
  }

  .form-submit {
    width: 100%;
    background: #1D5FBF;
    color: #FFFFFF;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    padding: 14px 20px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(29,95,191,0.35);
    transition: background 0.2s ease, transform 0.15s ease;
    margin-top: 2px;
  }

  .form-submit:hover {
    background: #174EA6;
    transform: translateY(-1px);
  }

  .form-reassurance {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .form-reassurance div {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: #6B7280;
  }

  .form-check {
    color: #16A34A;
    font-size: 12px;
    flex-shrink: 0;
  }

  .form-cal {
    font-size: 12px;
    color: #9CA3AF;
    text-align: center;
    line-height: 1.6;
    margin: 2px 0 0 0;
  }

  .form-cal a {
    color: #4B5563;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .form-cal a:hover { color: #1D5FBF; }

  /* ================================
     RESPONSIVE
     ================================ */
  @media (max-width: 1024px) {
    .offer-inner { padding: 64px 32px; }
  }

  @media (max-width: 860px) {
    .offer-inner { padding: 56px 20px; }

    .offer-header { margin-bottom: 48px; }

    .offer-layout {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    /* Contenu d'abord, formulaire en dessous */
    .offer-left  { order: 1; }
    .offer-right { order: 2; position: static; }

    .offer-form-card { padding: 28px 22px; }

    .form-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 520px) {
    .founder-secondary-grid { grid-template-columns: 1fr; }
    .offer-title { font-size: 36px; }
  }
</style>

<script>
  // ========================================
  // OFFER FORM
  // ========================================
  function submitOfferForm() {
    const prenom  = document.getElementById('offer-prenom').value.trim();
    const nom     = document.getElementById('offer-nom').value.trim();
    const societe = document.getElementById('offer-societe').value.trim();
    const email   = document.getElementById('offer-email').value.trim();
    const tel     = document.getElementById('offer-tel').value.trim();
    const consent = document.getElementById('offer-consent').checked;
    let hasError  = false;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const telRegex   = /^(\+33|0)[0-9](\s?\d{2}){4}$/;

    if (!prenom)  { document.getElementById('offer-prenom').style.borderColor  = '#ef4444'; hasError = true; }
    if (!nom)     { document.getElementById('offer-nom').style.borderColor     = '#ef4444'; hasError = true; }
    if (!societe) { document.getElementById('offer-societe').style.borderColor = '#ef4444'; hasError = true; }
    if (!email || !emailRegex.test(email)) { document.getElementById('offer-email').style.borderColor = '#ef4444'; hasError = true; }
    if (!tel || !telRegex.test(tel.replace(/\s/g, ''))) { document.getElementById('offer-tel').style.borderColor = '#ef4444'; hasError = true; }
    if (!consent) { document.getElementById('offer-consent').closest('label').style.color = '#ef4444'; hasError = true; }
    if (hasError) return;

    window.location.href = '/merci';
  }

  document.querySelectorAll('.form-input').forEach(input => {
    input.addEventListener('focus', () => { input.style.borderColor = ''; });
  });

  window.submitOfferForm = submitOfferForm;

  // ========================================
  // COMPTEUR ENTREPRISES FONDATRICES
  // ========================================
  const FOUNDERS_API_URL = '/api/count';

  async function loadFounderCount() {
    if (!FOUNDERS_API_URL) return;
    try {
      const res   = await fetch(FOUNDERS_API_URL);
      if (!res.ok) return;
      const data  = await res.json();
      const count = data.count ?? data.length ?? data;
      if (typeof count === 'number') {
        const el  = document.getElementById('founder-count');
        const el2 = document.getElementById('founder-count2');
        if (el)  { el.textContent  = String(count); }
        if (el2) { el2.textContent = String(count); el2.style.color = '#111827'; }
      }
    } catch (e) { /* silently fail */ }
  }

  loadFounderCount();
</script>
