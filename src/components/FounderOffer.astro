---
---
<section id="offre-fondateur" class="cta-band">
  <div class="cta-band-inner">

<h2 class="cta-title reveal reveal-delay-1">
      R&eacute;serve ton <span style="display:inline-block;position:relative;color:var(--fond);background:var(--terracotta);border-radius:14px;padding:0.04em 0.22em 0.10em;transform:rotate(-0.5deg);transform-origin:center;box-shadow:inset 0 -4px 0 rgba(0,0,0,0.12);">employ&eacute; IA</span>
    </h2>
    <p class="cta-claim reveal reveal-delay-2">
      D&eacute;couvre les avantages pour ton entreprise
    </p>

    <form
      class="cta-form reveal reveal-delay-2"
      id="fondateur-form"
      novalidate
    >
      <!-- Honeypot anti-spam -->
      <input type="text" id="offer-trap" name="_trap" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;pointer-events:none;" />

      <label for="email-fondateur">Ton adresse email</label>
      <input
        type="email"
        id="email-fondateur"
        name="email"
        placeholder="ton@email.fr"
        autocomplete="email"
        required
      >
      <span class="input-error" id="email-error" role="alert">Adresse email invalide.</span>
      <button type="submit" class="btn-primary">
        Je suis intéressé
      </button>
      <p class="cta-social-proof">
        Les 100 premiers b&eacute;n&eacute;ficient d&rsquo;un tarif exclusif.
      </p>
    </form>

    <div class="form-success" id="form-success" role="status">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7A8C3A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
      <div>
        <p class="form-success-title">Bienvenue parmi les Reccolteurs.</p>
        <p class="form-success-sub">Je reviens vers toi sous 24h pour poser les bases.</p>
      </div>
    </div>

  </div>
</section>

<style>
  .cta-band {
    background: #0D1207;
    border-top: 1px solid rgba(122, 140, 58, 0.15);
    padding: clamp(1.25rem, 3vw, 2rem) clamp(1.25rem, 5vw, 2.5rem) clamp(1.75rem, 4vw, 2.75rem);
  }

  .cta-band-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

.cta-title .highlight {
    display: inline-block;
    position: relative;
    color: var(--fond);
    background: var(--terracotta);
    border-radius: 14px;
    padding: 0.04em 0.22em 0.10em;
    transform: rotate(-0.5deg);
    transform-origin: center;
    box-shadow: inset 0 -4px 0 rgba(0,0,0,0.12);
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(29px, 3.8vw, 53px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--fond);
    margin-bottom: 1rem;
  }

  .cta-claim {
    font-family: var(--font-body);
    font-style: normal;
    font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: rgba(245, 243, 238, 0.90);
    line-height: 1.68;
    max-width: 44ch;
    margin: 0 auto 2rem;
  }

  .cta-claim em {
    font-style: normal;
    color: var(--terracotta);
  }

  .cta-form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .cta-form label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(245, 243, 238, 1);
    text-align: center;
  }

  .cta-form input[type="email"] {
    width: 100%;
    padding: 0.875rem 1.125rem;
    background: rgba(245, 243, 238, 0.07);
    border: 1px solid rgba(245, 243, 238, 0.14);
    border-radius: 3px;
    color: var(--fond);
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    -webkit-appearance: none;
    box-sizing: border-box;
  }
  .cta-form input[type="email"]::placeholder { color: rgba(245, 243, 238, 0.28); }
  .cta-form input[type="email"]:focus {
    border-color: var(--olive);
    background: rgba(245, 243, 238, 0.11);
  }
  .cta-form input.error { border-color: #c05050; }

  .input-error {
    font-family: var(--font-display);
    font-size: 0.78rem;
    color: #d06060;
    display: none;
    text-align: left;
  }
  .input-error.visible { display: block; }

  .btn-primary {
    margin-top: 0.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.75rem;
    background: linear-gradient(160deg, #8A9E42 0%, #6B7C32 100%);
    color: var(--fond);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 4px 20px -4px rgba(90, 110, 30, 0.50);
    transition: filter 0.18s ease, box-shadow 0.18s ease, transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-primary:hover {
    filter: brightness(1.08);
    box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 8px 28px -4px rgba(90, 110, 30, 0.60);
    transform: translateY(-1px);
  }
  .btn-primary:active { transform: translateY(0px) scale(0.98); filter: brightness(0.96); }

  .cta-social-proof {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    color: rgba(245, 243, 238, 0.85);
    margin-top: 0.75rem;
    text-align: center;
  }

  .cta-rgpd {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: rgba(245, 243, 238, 0.38);
    margin-top: 0.5rem;
    text-align: center;
    line-height: 1.5;
  }

  .cta-rgpd a {
    color: rgba(245, 243, 238, 0.55);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .form-success {
    display: none;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: rgba(122, 140, 58, 0.14);
    border: 1px solid rgba(122, 140, 58, 0.28);
    border-radius: 6px;
    max-width: 400px;
    margin: 0 auto;
  }
  .form-success.visible { display: flex; }

  .form-success-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--fond);
    margin: 0 0 0.4rem;
  }

  .form-success-sub {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(245, 243, 238, 0.65);
    margin: 0;
    line-height: 1.6;
  }

  .form-success-sub a {
    color: var(--olive);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

<script>
  function getUTMParams() {
    const p = new URLSearchParams(window.location.search);
    return {
      utm_source:   p.get('utm_source')   ?? '',
      utm_medium:   p.get('utm_medium')   ?? '',
      utm_campaign: p.get('utm_campaign') ?? '',
    };
  }

  function detectSource() {
    const utm = new URLSearchParams(window.location.search).get('utm_source');
    if (utm) return utm;
    const ref = document.referrer;
    if (!ref) return 'direct';
    try { return new URL(ref).hostname; } catch { return 'direct'; }
  }

  const form       = document.getElementById('fondateur-form');
  const emailInput = document.getElementById('email-fondateur') as HTMLInputElement;
  const emailError = document.getElementById('email-error');
  const formSuccess = document.getElementById('form-success');

  const isValidEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());

  emailInput.addEventListener('input', () => {
    if (emailInput.classList.contains('error') && isValidEmail(emailInput.value)) {
      emailInput.classList.remove('error');
      emailError!.classList.remove('visible');
    }
  });

  form!.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!isValidEmail(emailInput.value)) {
      emailInput.classList.add('error');
      emailError!.classList.add('visible');
      emailInput.focus();
      return;
    }

    const btn  = form!.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours\u2026';

    const email = encodeURIComponent(emailInput.value.trim());
    window.location.href = `/formulaire?email=${email}`;
  });
</script>
