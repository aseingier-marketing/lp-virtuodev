<style>
  .prob-grid {
    display: grid;
    grid-template-columns: 0.7fr 1.4fr;
    gap: 80px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Carousel wrapper ── */
  .prob-carousel {
    position: relative;
    user-select: none;
  }

  /* ── Progress bar ── */
  .prob-progress-track {
    height: 2px;
    background: rgba(0,0,0,0.08);
    border-radius: 2px;
    margin-bottom: 44px;
    overflow: hidden;
  }

  .prob-progress-fill {
    height: 100%;
    width: 0%;
    background: #2563EB;
    border-radius: 2px;
    transition: width 0.05s linear;
  }

  /* ── Dots ── */
  .prob-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .prob-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.12);
    background-clip: content-box;
    border: none;
    cursor: pointer;
    /* Zone de touch 44×44px via padding (WCAG 2.5.5) */
    padding: 18px;
    margin: -18px;
    box-sizing: content-box;
    transition: background 0.25s ease, transform 0.25s ease, width 0.25s ease;
    flex-shrink: 0;
  }

  .prob-dot:focus-visible {
    outline: 3px solid #2563EB;
    outline-offset: 4px;
    border-radius: 4px;
  }

  .prob-dot.active {
    background: #2563EB;
    background-clip: content-box;
    width: 24px;
    border-radius: 4px;
  }

  /* ── Stat slide ── */
  .prob-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }

  .prob-slide.active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .prob-slide.exit {
    position: absolute;
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
  }

  /* ── Number ── */
  .prob-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(56px, 7.7vw, 95px);
    letter-spacing: -0.04em;
    line-height: 1;
    color: #101828;
  }

  .prob-number sup {
    font-size: 0.48em;
    vertical-align: super;
    letter-spacing: -0.02em;
  }

  /* ── Phrase ── */
  .prob-phrase {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 18px);
    color: #475467;
    line-height: 1.65;
    margin-top: 20px;
    max-width: 300px;
  }

  /* ── Arrow buttons ── */
  .prob-arrows {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 40px;
  }

  .prob-arrow-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #F5F7FB;
    border: 1px solid #E6EAF2;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #101828;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
    flex-shrink: 0;
  }

  .prob-arrow-btn:hover {
    background: #EBF0FF;
    border-color: #C7D7FF;
    transform: scale(1.07);
  }

  .prob-arrow-btn:active {
    transform: scale(0.96);
  }

  .prob-arrow-btn svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Slide container (needs height for absolute children) ── */
  .prob-slides-wrap {
    position: relative;
    min-height: 180px;
  }

  @media (max-width: 768px) {
    .prob-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .prob-phrase {
      max-width: 100%;
    }
  }
</style>

<!-- Section Le Problème -->
<section class="section-pad" style="background:#FFFFFF; overflow:hidden;">
  <div class="section-inner">
    <div class="prob-grid">

      <!-- Colonne gauche — carousel -->
      <div class="prob-carousel">

        <!-- En-tête : label + compteur -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
          <span style="font-family:var(--font-body); font-size:13px; font-weight:600; color:#101828; letter-spacing:0.04em; text-transform:uppercase;">Données clés</span>
          <span id="prob-counter" style="font-family:var(--font-display); font-size:13px; font-weight:700; color:#98A2B3; letter-spacing:0.04em;">01 / 03</span>
        </div>

        <!-- Barre de progression -->
        <div class="prob-progress-track">
          <div class="prob-progress-fill" id="prob-progress"></div>
        </div>

        <!-- Slides -->
        <div class="prob-slides-wrap" id="prob-slides-wrap">

          <div class="prob-slide active" data-index="0">
            <div class="prob-number">44<sup>%</sup></div>
            <p class="prob-phrase">des commerciaux abandonnent après une seule relance.</p>
          </div>

          <div class="prob-slide" data-index="1">
            <div class="prob-number">80<sup>%</sup></div>
            <p class="prob-phrase">des ventes nécessitent 5 contacts ou plus pour aboutir.</p>
          </div>

          <div class="prob-slide" data-index="2">
            <div class="prob-number">55<sup>%</sup></div>
            <p class="prob-phrase">des réponses arrivent grâce à une relance au bon moment.</p>
          </div>

        </div>

        <!-- Navigation -->
        <div class="prob-arrows">
          <button class="prob-arrow-btn" id="prob-prev" aria-label="Précédent">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="prob-arrow-btn" id="prob-next" aria-label="Suivant">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <!-- Dots -->
          <div class="prob-dots" id="prob-dots" style="margin-left:8px;">
            <button class="prob-dot active" data-dot="0" aria-label="Slide 1"></button>
            <button class="prob-dot"        data-dot="1" aria-label="Slide 2"></button>
            <button class="prob-dot"        data-dot="2" aria-label="Slide 3"></button>
          </div>
        </div>

      </div>

      <!-- Colonne droite — titre -->
      <div>
        <h2 style="font-family:var(--font-display); font-weight:800; font-size:clamp(26px,3vw,38px); letter-spacing:-0.03em; line-height:1.12; color:#101828; margin:0;">
          Combien de devis avez-vous envoyés le mois dernier&nbsp;?<br>
          <span style="color:#2563EB;">Combien ont signé&nbsp;?</span>
        </h2>
        <p style="font-family:var(--font-body); font-weight:500; font-size:clamp(16px,1.5vw,19px); line-height:1.65; color:#475467; margin:24px 0 0 0; max-width:480px;">
          Chaque mois, ce sont des dizaines de propositions qui n&rsquo;aboutissent pas.
        </p>
        <button style="display:inline-flex; align-items:center; justify-content:center; margin-top:40px; padding:14px 26px; border-radius:11px; font-family:var(--font-body); font-weight:600; font-size:16px; cursor:pointer; border:none; background:#1D5FBF; color:#FFFFFF; transition:background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease; box-shadow:0px 10px 25px rgba(29,95,191,0.35);"
          onmouseover="this.style.background='#174EA6';this.style.transform='translateY(-2px)';this.style.boxShadow='0px 14px 32px rgba(29,95,191,0.45)'"
          onmouseout="this.style.background='#1D5FBF';this.style.transform='translateY(0)';this.style.boxShadow='0px 10px 25px rgba(29,95,191,0.35)'">
          Arr&ecirc;ter de perdre des devis &rarr;
        </button>
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    const DURATION = 5000; // ms par slide
    const TICK     = 50;   // ms entre chaque mise à jour de la barre

    const slides   = Array.from(document.querySelectorAll('.prob-slide'));
    const dots     = Array.from(document.querySelectorAll('.prob-dot'));
    const elCounter  = document.getElementById('prob-counter');
    const elProgress = document.getElementById('prob-progress');

    let current  = 0;
    let elapsed  = 0;
    let ticker   = null;
    let paused   = false;

    /* ── Transition vers un slide ── */
    function goTo(idx, dir) {
      if (idx === current) return;

      const prev = current;
      current = (idx + slides.length) % slides.length;

      // exit ancien
      slides[prev].classList.remove('active');
      slides[prev].classList.add('exit');
      setTimeout(() => slides[prev].classList.remove('exit'), 450);

      // enter nouveau
      slides[current].classList.add('active');

      // dots
      dots[prev].classList.remove('active');
      dots[current].classList.add('active');

      // compteur
      elCounter.textContent = String(current + 1).padStart(2, '0') + ' / 0' + slides.length;

      // reset barre
      elapsed = 0;
      elProgress.style.transition = 'none';
      elProgress.style.width = '0%';
    }

    function goNext() { goTo(current + 1); }
    function goPrev() { goTo(current - 1); }

    /* ── Ticker (barre de progression) ── */
    function startTicker() {
      clearInterval(ticker);
      ticker = setInterval(() => {
        if (paused) return;
        elapsed += TICK;
        const pct = Math.min((elapsed / DURATION) * 100, 100);
        elProgress.style.transition = 'none';
        elProgress.style.width = pct + '%';
        if (elapsed >= DURATION) {
          elapsed = 0;
          goNext();
        }
      }, TICK);
    }

    /* ── Pause au hover ── */
    const carousel = document.querySelector('.prob-carousel');
    carousel.addEventListener('mouseenter', () => { paused = true; });
    carousel.addEventListener('mouseleave', () => { paused = false; });

    /* ── Boutons ── */
    document.getElementById('prob-next').addEventListener('click', () => { goNext(); elapsed = 0; });
    document.getElementById('prob-prev').addEventListener('click', () => { goPrev(); elapsed = 0; });

    /* ── Dots ── */
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); });
    });

    /* ── Swipe tactile ── */
    let touchStartX = 0;
    const wrap = document.getElementById('prob-slides-wrap');
    wrap.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    wrap.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) { dx < 0 ? goNext() : goPrev(); elapsed = 0; }
    });

    startTicker();
  })();
</script>
