---
---
<section id="section-relances" class="section-dark section-pad" style="background:#0C1222;border-top:1px solid rgba(29,95,191,0.15);">
  <div class="section-inner">

    <!-- En-tête 2 colonnes -->
    <div class="why-header gs-hidden" data-gs="s3" data-gs-delay="0.05">
      <h2 class="why-title">Relancez mieux,<br>pour signer plus.</h2>
      <div>
        <p class="why-desc">Virtuodev vous donne une vision claire de votre suivi commercial.</p>
        <p class="why-desc" style="margin-top:8px;">Plus de devis oubli&eacute;s, plus de prospects sans nouvelles&nbsp;: vous voyez exactement qui a ouvert votre devis, qui a re&ccedil;u une relance, et qui doit &ecirc;tre rappel&eacute;.</p>
      </div>
    </div>

    <!-- 4 cards -->
    <div class="why-cards gs-hidden" data-gs="s3" data-gs-delay="0.12">

      <!-- Card 1 -->
      <div class="why-card">
        <h3 class="why-card-title">Tous vos devis en cours, d&rsquo;un seul coup d&rsquo;&oelig;il</h3>
        <p class="why-card-desc">Visualisez tous vos devis en attente, le nombre de relances et le tracking d&rsquo;ouverture.</p>
        <div class="why-mock">
          <div class="mock-tag">Devis envoy&eacute;s</div>
          <div class="mock-big-num">8 <span class="mock-big-unit">en attente</span></div>
          <div class="mock-sub-text">objectif&nbsp;: 3 signatures ce mois</div>
          <div class="mock-progress-track">
            <div class="mock-progress-fill" style="width:35%;"></div>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="why-card">
        <h3 class="why-card-title">Un alli&eacute; anti charge mentale</h3>
        <p class="why-card-desc">Chaque devis est relancé automatiquement, en suivant un ordre de relance précis, pour vous faire gagner du temps.</p>
        <div class="why-mock why-mock--center">
          <svg width="110" height="62" viewBox="0 0 110 62" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10,55 A45,45 0 0,1 100,55" stroke="rgba(255,255,255,0.08)" stroke-width="13" stroke-linecap="round" fill="none"/>
            <path d="M10,55 A45,45 0 0,1 55,10" stroke="#4D8EE8" stroke-width="13" stroke-linecap="round" fill="none"/>
            <path d="M55,10 A45,45 0 0,1 100,55" stroke="#7B61FF" stroke-width="13" stroke-linecap="round" fill="none"/>
          </svg>
          <div class="mock-donut-legend">
            <span class="mock-legend-item"><span class="mock-dot mock-dot--blue"></span>3 &agrave; relancer</span>
            <span class="mock-legend-item"><span class="mock-dot mock-dot--purple"></span>12 en veille</span>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="why-card">
        <h3 class="why-card-title">Le bon message, au bon moment</h3>
        <p class="why-card-desc">Chaque relance est personnalis&eacute;e selon le profil du prospect et l&rsquo;&eacute;tape du devis, pour maximiser vos chances de signature.</p>
        <div class="why-mock why-mock--messages">
          <div class="mock-msg-row">
            <span class="mock-msg-tag mock-msg-tag--cold">Froid</span>
            <span class="mock-msg-text">Rappel de devis envoy&eacute;</span>
          </div>
          <div class="mock-msg-row">
            <span class="mock-msg-tag mock-msg-tag--warm">Tiède</span>
            <span class="mock-msg-text">Relance + photo chantier</span>
          </div>
          <div class="mock-msg-row">
            <span class="mock-msg-tag mock-msg-tag--hot">Chaud</span>
            <span class="mock-msg-text">Offre &agrave; dur&eacute;e limit&eacute;e</span>
          </div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="why-card">
        <h3 class="why-card-title">Des d&eacute;cisions appuy&eacute;es sur des donn&eacute;es</h3>
        <p class="why-card-desc">Les donn&eacute;es analysent les relances, les taux d&rsquo;ouverture, et am&eacute;liorent en continu les s&eacute;quences de relances.</p>
        <div class="why-mock">
          <div class="mock-chart-header">
            <span class="mock-chart-month">Avril</span>
            <span class="mock-chart-real">R&eacute;el</span>
          </div>
          <svg class="mock-chart-svg" viewBox="0 0 200 56" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#7B61FF" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="#7B61FF" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0 45 C30 42, 50 30, 80 28 S130 35, 160 18 S185 12, 200 8 L200 56 L0 56 Z" fill="url(#chartGrad)"/>
            <path d="M0 45 C30 42, 50 30, 80 28 S130 35, 160 18 S185 12, 200 8" stroke="#7B61FF" stroke-width="2" fill="none" stroke-linecap="round"/>
          </svg>
          <div class="mock-chart-value">+32&nbsp;%</div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ── EN-TÊTE ─────────────────────────────── */
  .why-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto 64px;
  }

  .why-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(34px, 4.5vw, 62px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: #FFFFFF;
    margin: 0;
  }

  .why-desc {
    font-family: var(--font-body);
    font-size: clamp(15px, 1.4vw, 17px);
    color: var(--text-dark-secondary, rgba(255,255,255,0.55));
    line-height: 1.7;
    margin: 0;
    padding-top: 6px;
  }

  /* ── GRILLE 4 CARDS ──────────────────────── */
  .why-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .why-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.055) 0%, rgba(255,255,255,0.025) 100%);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 20px;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .why-card:hover {
    border-color: rgba(77,142,232,0.30);
    background: linear-gradient(145deg, rgba(77,142,232,0.07) 0%, rgba(255,255,255,0.03) 100%);
  }

  .why-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(17px, 1.6vw, 20px);
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: #FFFFFF;
    margin: 0;
  }

  .why-card-desc {
    font-family: var(--font-body);
    font-size: clamp(13px, 1.1vw, 14px);
    color: var(--text-dark-secondary, rgba(255,255,255,0.50));
    line-height: 1.6;
    margin: 0 0 4px;
  }

  /* ── MOCKUP BASE ─────────────────────────── */
  .why-mock {
    margin-top: auto;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 18px 16px 14px;
  }

  .why-mock--center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .why-mock--pie {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* ── MOCKUP CARD 1 ───────────────────────── */
  .mock-tag {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #4D8EE8;
    margin-bottom: 6px;
  }

  .mock-big-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(26px, 2.8vw, 34px);
    letter-spacing: -0.03em;
    color: #FFFFFF;
    line-height: 1.1;
  }

  .mock-big-unit {
    font-size: 0.5em;
    font-weight: 600;
    color: rgba(255,255,255,0.40);
    letter-spacing: 0;
  }

  .mock-sub-text {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    margin: 4px 0 14px;
  }

  .mock-progress-track {
    height: 5px;
    background: rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .mock-progress-fill {
    height: 100%;
    background: #4D8EE8;
    border-radius: 4px;
  }

  /* ── MOCKUP CARD 2 (donut) ───────────────── */
  .mock-donut-legend {
    display: flex;
    gap: 14px;
    justify-content: center;
  }

  /* ── MOCKUP CARD 3 (messages) ───────────── */
  .why-mock--messages {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mock-msg-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .mock-msg-tag {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    border-radius: 6px;
    padding: 3px 8px;
    flex-shrink: 0;
    min-width: 46px;
    text-align: center;
  }

  .mock-msg-tag--cold   { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.45); }
  .mock-msg-tag--warm   { background: rgba(245,197,66,0.15);  color: #F5C542; }
  .mock-msg-tag--hot    { background: rgba(77,142,232,0.18);  color: #7FB3F5; }

  .mock-msg-text {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── MOCKUP CARD 4 (chart) ───────────────── */
  .mock-chart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .mock-chart-month {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: #FFFFFF;
  }

  .mock-chart-real {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 2px 7px;
  }

  .mock-chart-svg {
    width: 100%;
    height: 50px;
    display: block;
  }

  .mock-chart-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 20px;
    letter-spacing: -0.02em;
    color: #7B61FF;
    margin-top: 8px;
  }

  /* ── DOTS légende ────────────────────────── */
  .mock-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.55);
  }

  .mock-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .mock-dot--blue   { background: #4D8EE8; }
  .mock-dot--purple { background: #7B61FF; }
  .mock-dot--yellow { background: #F5C542; }

  /* ── RESPONSIVE ──────────────────────────── */
  @media (max-width: 900px) {
    .why-header {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .why-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .why-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
