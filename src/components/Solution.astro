---
---
<!-- Section 4 — Comment ça marche (fond blanc) -->
<section class="section-light section-pad" style="background:#FFFFFF;border-top:1px solid var(--border-light);">
  <div class="section-inner">

    <!-- Badge -->
    <div class="gs-hidden" data-gs="s4" data-gs-delay="0" style="display:flex;justify-content:center;margin-bottom:20px;">
      <div style="display:inline-flex;align-items:center;gap:9px;background:linear-gradient(180deg,rgba(59,130,246,0.08) 0%,rgba(59,130,246,0.04) 100%);border:1px solid rgba(59,130,246,0.28);border-radius:100px;padding:8px 18px;box-shadow:0 0 0 1px rgba(59,130,246,0.06),0 0 24px rgba(59,130,246,0.12);">
        <span style="width:18px;height:18px;border-radius:999px;background:rgba(59,130,246,0.14);border:1px solid rgba(96,165,250,0.28);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        <span style="font-family:var(--font-body);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#2563EB;">Comment &ccedil;a fonctionne</span>
      </div>
    </div>

    <h2 class="h1 gs-hidden" data-gs="s4" data-gs-delay="0.1" style="color:var(--text-light-primary);max-width:700px;margin-left:auto;margin-right:auto;text-align:center;">On relance vos devis &agrave; votre place</h2>

    <!-- Compatible tools -->
    <div class="gs-hidden" data-gs="s4" data-gs-delay="0.15" style="margin-top:16px;text-align:center;">
      <p style="font-family:var(--font-body);font-size:16px;color:var(--text-light-secondary);max-width:560px;margin:0 auto;line-height:1.65;">
        Compatible avec la majorit&eacute; des logiciels de devis&nbsp;<strong style="color:var(--text-light-primary);">(Axonaut, Sellsy, Extrabat&hellip; et 20+ autres)</strong>. Pas de migration, pas de formation.
      </p>
    </div>

    <!-- Steps -->
    <div class="gs-hidden" data-gs="s4" data-gs-delay="0.2" style="margin-top:56px;max-width:820px;margin-left:auto;margin-right:auto;display:flex;flex-direction:column;gap:0;">

      <!-- Step 1 -->
      <div class="s4-step">
        <div class="s4-step-num">01</div>
        <div class="s4-step-body">
          <div class="s4-step-title">Envoyez vos devis depuis votre logiciel habituel</div>
          <div class="s4-step-desc">Vous ne changez rien &agrave; votre fa&ccedil;on de travailler.</div>
        </div>
      </div>

      <!-- Connector -->
      <div class="s4-connector"><div class="s4-connector-line"></div></div>

      <!-- Step 2 -->
      <div class="s4-step s4-step--highlight">
        <div class="s4-step-num s4-step-num--highlight">02</div>
        <div class="s4-step-body">
          <div class="s4-step-title">On lance automatiquement les relances</div>
          <div class="s4-step-desc">Personnalis&eacute;, au bon moment, sur le bon canal, sans que vous ayez &agrave; y penser.</div>
          <!-- Channels chips -->
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;">
            <span class="s4-channel-chip">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
              Email
            </span>
            <span class="s4-channel-chip">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              SMS
            </span>
            <span class="s4-channel-chip">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              WhatsApp
            </span>
          </div>
        </div>
      </div>

      <!-- Connector -->
      <div class="s4-connector"><div class="s4-connector-line"></div></div>

      <!-- Step 3 -->
      <div class="s4-step">
        <div class="s4-step-num">03</div>
        <div class="s4-step-body">
          <div class="s4-step-title">Prospect chaud&nbsp;? Vous signez.</div>
          <div class="s4-step-desc">Pas de r&eacute;ponse imm&eacute;diate&nbsp;? On garde le contact sur le long terme jusqu'&agrave; la d&eacute;cision, en restant discret.</div>
        </div>
      </div>

    </div>

    <!-- Footer callout -->
    <div class="gs-hidden" data-gs="s4" data-gs-delay="0.3" style="margin-top:56px;text-align:center;">
      <div class="s4-callout-box" style="display:inline-block;background:rgba(29,95,191,0.05);border:1px solid rgba(29,95,191,0.16);border-radius:14px;padding:18px 32px;">
        <p style="font-family:var(--font-display);font-weight:700;font-size:clamp(17px,1.8vw,20px);color:var(--text-light-primary);letter-spacing:-0.01em;margin:0;">On param&egrave;tre tout. Vous n'installez rien.</p>
      </div>
      <div style="margin-top:32px;">
        <button style="display:inline-flex;align-items:center;justify-content:center;padding:14px 26px;border-radius:11px;font-family:var(--font-body);font-weight:600;font-size:16px;cursor:pointer;border:none;background:#1D5FBF;color:#FFFFFF;transition:background 0.2s ease,transform 0.2s ease,box-shadow 0.2s ease;box-shadow:0px 10px 25px rgba(29,95,191,0.35);" onclick="document.getElementById('section-callback').scrollIntoView({behavior:'smooth'})" onmouseover="this.style.background='#174EA6';this.style.transform='translateY(-2px)';this.style.boxShadow='0px 14px 32px rgba(29,95,191,0.45)'" onmouseout="this.style.background='#1D5FBF';this.style.transform='translateY(0)';this.style.boxShadow='0px 10px 25px rgba(29,95,191,0.35)'">
          Demander sa place &rarr;
        </button>
        <div style="font-size:13px;font-weight:600;color:var(--text-light-secondary);margin-top:10px;letter-spacing:0.01em;">Phase limit&eacute;e &agrave; 100 entreprises</div>
      </div>
    </div>

  </div>
</section>

<style>
  .s4-step {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 28px 32px;
    border-radius: 16px;
    background: #FFFFFF;
    border: 1px solid var(--border-light);
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .s4-step--highlight {
    background: rgba(29,95,191,0.04);
    border-color: rgba(29,95,191,0.22);
    box-shadow: 0 4px 20px rgba(29,95,191,0.08);
  }
  .s4-step-num {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #F5F7FB;
    border: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    color: #475467;
    letter-spacing: -0.01em;
    margin-top: 2px;
  }
  .s4-step-num--highlight {
    background: #1D5FBF;
    border-color: #1D5FBF;
    color: #FFFFFF;
  }
  .s4-step-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 19px;
    color: var(--text-light-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .s4-step-desc {
    font-family: var(--font-body);
    font-size: 15.5px;
    color: var(--text-light-secondary);
    line-height: 1.65;
    margin-top: 6px;
  }
  .s4-connector {
    display: flex;
    justify-content: flex-start;
    padding-left: 54px;
    height: 28px;
  }
  .s4-connector-line {
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg, rgba(29,95,191,0.20) 0%, rgba(29,95,191,0.10) 100%);
    border-radius: 2px;
  }
  .s4-channel-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(29,95,191,0.08);
    border: 1px solid rgba(29,95,191,0.20);
    font-size: 12.5px;
    font-weight: 600;
    color: #1D5FBF;
    letter-spacing: 0.01em;
  }
  .s5-list {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .s5-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--text-light-secondary);
    line-height: 1.5;
  }
  .s5-list li strong {
    color: var(--text-light-primary);
    font-weight: 600;
  }
  .s5-list-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #1D5FBF;
    margin-top: 6px;
    opacity: 0.6;
  }
  @media (max-width: 768px) {
    .s4-step {
      padding: 20px 18px;
      gap: 16px;
    }
    .s4-connector {
      padding-left: 41px;
    }
    .s4-callout-box {
      padding: 16px 20px !important;
    }
    .s5-features-grid {
      margin-top: 36px !important;
    }
    .s5-summary {
      margin-top: 36px !important;
      padding-top: 32px !important;
    }
  }
</style>

<!-- Section 5 — Notre Différence (fond bleu léger) -->
<section class="section-light section-pad" style="background:#EEF4FF;border-top:1px solid rgba(29,95,191,0.10);">
  <div class="section-inner">

    <!-- Badge -->
    <div class="gs-hidden" data-gs="s5" data-gs-delay="0" style="display:flex;justify-content:center;margin-bottom:20px;">
      <div style="display:inline-flex;align-items:center;gap:9px;background:linear-gradient(180deg,rgba(59,130,246,0.08) 0%,rgba(59,130,246,0.04) 100%);border:1px solid rgba(59,130,246,0.28);border-radius:100px;padding:8px 18px;box-shadow:0 0 0 1px rgba(59,130,246,0.06),0 0 24px rgba(59,130,246,0.12);">
        <span style="width:18px;height:18px;border-radius:999px;background:rgba(59,130,246,0.14);border:1px solid rgba(96,165,250,0.28);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        <span style="font-family:var(--font-body);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#2563EB;">Notre diff&eacute;rence</span>
      </div>
    </div>

    <h2 class="h1 gs-hidden" data-gs="s5" data-gs-delay="0.1" style="color:var(--text-light-primary);max-width:700px;margin-left:auto;margin-right:auto;text-align:center;">Des relances adapt&eacute;es au comportement du prospect</h2>
    <p class="gs-hidden" data-gs="s5" data-gs-delay="0.15" style="font-family:var(--font-body);font-size:17px;color:var(--text-light-secondary);max-width:560px;margin:20px auto 0;text-align:center;line-height:1.65;">Pas de spam. Pas de s&eacute;quence g&eacute;n&eacute;rique. Juste la <strong style="color:var(--text-light-primary);">bonne relance</strong>, au <strong style="color:var(--text-light-primary);">bon moment</strong>, sur le <strong style="color:var(--text-light-primary);">bon canal</strong>.</p>

    <div class="s5-features-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:56px;">
      <div class="gs-hidden" data-gs="s5" data-gs-delay="0.2" style="background:var(--bg-light-card);border:1px solid var(--border-light);border-radius:16px;padding:28px 22px;box-shadow:0 4px 16px rgba(0,0,0,0.05);text-align:left;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--accent-dim);display:flex;align-items:center;justify-content:center;color:var(--accent);flex-shrink:0;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:18px;color:var(--text-light-primary);letter-spacing:-0.01em;">Adaptation en temps r&eacute;el</h3>
        </div>
        <ul class="s5-list">
          <li><span class="s5-list-dot"></span><span>Ouvert 3 fois sans r&eacute;ponse&nbsp;? &rarr; <strong>SMS de rappel court</strong></span></li>
          <li><span class="s5-list-dot"></span><span>Jamais ouvert&nbsp;? &rarr; <strong>Changement d'angle par email</strong></span></li>
          <li><span class="s5-list-dot"></span><span><strong>Chaque action d&eacute;clenche la relance suivante</strong></span></li>
        </ul>
      </div>
      <div class="gs-hidden" data-gs="s5" data-gs-delay="0.3" style="background:var(--bg-light-card);border:1px solid var(--border-light);border-radius:16px;padding:28px 22px;box-shadow:0 4px 16px rgba(0,0,0,0.05);text-align:left;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--accent-dim);display:flex;align-items:center;justify-content:center;color:var(--accent);flex-shrink:0;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3"/><path d="M16 8V2h6"/><path d="M22 2L12 12"/></svg>
          </div>
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:18px;color:var(--text-light-primary);letter-spacing:-0.01em;">Le canal qui convertit</h3>
        </div>
        <ul class="s5-list">
          <li><span class="s5-list-dot"></span><span><strong>Email</strong> pour le premier contact</span></li>
          <li><span class="s5-list-dot"></span><span><strong>SMS</strong> si pas d'ouverture</span></li>
          <li><span class="s5-list-dot"></span><span><strong>WhatsApp</strong> si engagement &eacute;lev&eacute;</span></li>
        </ul>
      </div>
      <div class="gs-hidden" data-gs="s5" data-gs-delay="0.4" style="background:var(--bg-light-card);border:1px solid var(--border-light);border-radius:16px;padding:28px 22px;box-shadow:0 4px 16px rgba(0,0,0,0.05);text-align:left;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;border-radius:10px;background:var(--accent-dim);display:flex;align-items:center;justify-content:center;color:var(--accent);flex-shrink:0;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 style="font-family:var(--font-display);font-weight:700;font-size:18px;color:var(--text-light-primary);letter-spacing:-0.01em;">Suivi jusqu'&agrave; la signature</h3>
        </div>
        <ul class="s5-list">
          <li><span class="s5-list-dot"></span><span><strong>Plus aucun prospect ne tombe dans l'oubli</strong></span></li>
          <li><span class="s5-list-dot"></span><span>Relances automatiques jusqu'&agrave; la r&eacute;ponse</span></li>
          <li><span class="s5-list-dot"></span><span>Stop uniquement sur&nbsp;: <strong>signature</strong> ou <strong>refus d&eacute;finitif</strong></span></li>
        </ul>
      </div>
    </div>

    <div class="gs-hidden s5-summary" data-gs="s5" data-gs-delay="0.5" style="margin-top:56px;padding-top:48px;border-top:1px solid var(--border-light);max-width:720px;margin-left:auto;margin-right:auto;text-align:center;">
      <p style="font-family:var(--font-display);font-weight:700;font-size:clamp(20px,2.2vw,26px);letter-spacing:-0.02em;color:var(--text-light-primary);line-height:1.4;">R&eacute;sultat&nbsp;: chaque prospect re&ccedil;oit la bonne relance, au bon moment, sur le bon canal. <strong style="color:#1D5FBF;">Sans intervention de votre part.</strong></p>
    </div>

  </div>
</section>
