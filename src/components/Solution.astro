<script>
  (function () {
    const cards = Array.from(document.querySelectorAll('.s4-card'));
    const dots = Array.from(document.querySelectorAll('.s4-progress .s4-dot'));
    if (!cards.length) return;

    // Skip on mobile (cards are always visible)
    if (window.matchMedia('(max-width: 768px)').matches) return;

    function setActive(index) {
      cards.forEach((card, i) => {
        card.classList.remove('is-visible', 'is-past');
        if (i === index) card.classList.add('is-visible');
        else if (i < index) card.classList.add('is-past');
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('s4-dot--active', i === index);
      });
    }

    // IntersectionObserver: activate card when it enters the middle of viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt(entry.target.dataset.card, 10);
            setActive(index);
          }
        });
      },
      {
        threshold: 0.55,
        rootMargin: '-10% 0px -10% 0px',
      }
    );

    cards.forEach((card) => observer.observe(card));

    // Dot click: scroll to card
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        cards[i].scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    });

    // Init: activate first card after a short delay
    setTimeout(() => {
      const rect = cards[0].getBoundingClientRect();
      if (rect.top < window.innerHeight) setActive(0);
    }, 200);
  })();
</script>

