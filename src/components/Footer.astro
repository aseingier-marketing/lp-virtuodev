<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">

      <!-- GAUCHE -->
      <div class="footer-col footer-col--left">
        <a href="/" class="footer-logo">
          <div class="footer-logo-crop">
            <img src="/images/reccolt-logo.png" alt="Reccolt" class="footer-logo-img" />
          </div>
        </a>
        <p class="footer-baseline">L&rsquo;outil de relance automatique<br>pour les artisans et ind&eacute;pendants.</p>
      </div>

      <!-- CENTRE -->
      <div class="footer-col footer-col--center">
        <span class="footer-col-label">Liens</span>
        <ul class="footer-links">
          <li><a href="/mentions-legales">Mentions l&eacute;gales</a></li>
          <li><a href="/politique-de-confidentialite">Confidentialit&eacute;</a></li>
          <li><a href="/politique-de-cookies">Cookies</a></li>
          <li><a href="/cgv">CGV</a></li>
        </ul>
      </div>

      <!-- DROITE -->
      <div class="footer-col footer-col--right">
        <span class="footer-col-label">Contact</span>
        <a href="mailto:contact@reccolt.com" class="footer-email">contact@reccolt.com</a>
        <a href="https://www.linkedin.com/in/aseingier/" target="_blank" rel="noopener noreferrer" class="footer-linkedin" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="footer-linkedin-arrow">
            <path d="M7 17L17 7M7 7h10v10"/>
          </svg>
        </a>
      </div>

    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; 2026 Reccolt &mdash; Tous droits r&eacute;serv&eacute;s</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--fond);
    font-family: var(--font-display);
    width: 100%;
  }

  .footer-inner {
    width: 100%;
    padding: 1.25rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    align-items: center;
    padding-bottom: 0.75rem;
  }

  /* LOGO + BASELINE */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 0.25rem;
  }

  .footer-logo-crop {
    width: 140px;
    height: 36px;
    overflow: hidden;
    position: relative;
  }

  .footer-logo-img {
    height: 200px;
    width: auto;
    mix-blend-mode: multiply;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .footer-baseline {
    font-size: 0.8rem;
    color: rgba(30, 42, 14, 0.38);
    margin: 0;
    line-height: 1.6;
  }

  /* COLONNES */
  .footer-col {
    display: flex;
    flex-direction: column;
  }

  .footer-col--center {
    align-items: center;
  }

  .footer-col--right {
    align-items: flex-end;
  }

  .footer-col-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(30, 42, 14, 0.3);
    margin-bottom: 0.4rem;
  }

  /* LIENS */
  .footer-links {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: rgba(30, 42, 14, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: var(--texte);
  }

  /* LINKEDIN */
  .footer-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 0.5rem;
    color: rgba(30, 42, 14, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-linkedin:hover {
    color: #0A66C2;
  }

  .footer-linkedin-arrow {
    opacity: 0.7;
  }

  /* EMAIL */
  .footer-email {
    font-size: 0.8rem;
    color: rgba(30, 42, 14, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-email:hover {
    color: #C97D55;
  }

  /* BOTTOM */
  .footer-bottom {
    padding-top: 0.75rem;
    border-top: 1px solid rgba(30, 42, 14, 0.09);
    text-align: center;
  }

  .footer-copy {
    font-size: 0.72rem;
    color: rgba(30, 42, 14, 0.25);
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .footer-inner {
      padding: 1rem 1.25rem;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-col--center,
    .footer-col--right {
      align-items: flex-start;
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
