---
---
<header class="site-header" id="site-header">
  <!-- Wordmark -->
  <a href="/" class="nav-logo">
    <img src="/images/reccolt-logo-header.png" alt="Reccolt" class="nav-logo-img" />
  </a>

  <!-- Nav links -->
  <nav class="nav-links" aria-label="Navigation principale">
    <a href="/#section-comment-ca-fonctionne" class="nav-link">Comment ça marche</a>
    <a href="/#section-pour-qui" class="nav-link">Pour qui</a>
    <a href="/#section-faq" class="nav-link">FAQ</a>
  </nav>

  <!-- CTA groupe + CTA principal -->
  <div class="nav-cta-group">
<a href="/formulaire" class="nav-cta">Rejoindre Reccolt</a>
  </div>

  <!-- Hamburger mobile -->
  <button class="nav-burger" id="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-mobile-menu">
    <span class="nav-burger-bar"></span>
    <span class="nav-burger-bar"></span>
    <span class="nav-burger-bar"></span>
  </button>
</header>

<!-- Menu mobile overlay -->
<div class="nav-mobile-menu" id="nav-mobile-menu" role="dialog" aria-modal="true" aria-label="Menu principal">
  <nav class="nav-mobile-links">
    <a href="/#section-comment-ca-fonctionne" class="nav-mobile-link">Comment ça marche</a>
    <a href="/#section-pour-qui" class="nav-mobile-link">Pour qui</a>
    <a href="/#section-faq" class="nav-mobile-link">FAQ</a>
  </nav>
  <a href="/formulaire" class="nav-mobile-cta">Rejoindre Reccolt</a>
</div>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 80px;
    background: rgba(245, 243, 238, 0);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .site-header.scrolled {
    background: rgba(245, 243, 238, 0.92);
    border-bottom-color: rgba(30, 42, 14, 0.10);
    box-shadow: 0 1px 12px rgba(30, 42, 14, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-logo {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    overflow: visible;
  }

  .nav-logo-img {
    height: 130px;
    width: auto;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 40px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    color: var(--texte-secondaire);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--texte);
  }

  .nav-cta-group {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .nav-cta-secondary {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--texte-secondaire);
    text-decoration: none;
    padding: 10px 16px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    white-space: nowrap;
    letter-spacing: 0.01em;
    border: 1px solid var(--border);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .nav-cta-secondary:hover {
    color: var(--texte);
    border-color: var(--texte-secondaire);
  }

  .nav-cta {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    color: var(--fond);
    background: linear-gradient(160deg, #8A9E42 0%, #6B7C32 100%);
    text-decoration: none;
    padding: 10px 22px;
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    border-radius: 6px;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 4px 14px -2px rgba(90, 110, 30, 0.40);
    transition: filter 0.18s ease, box-shadow 0.18s ease, transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-cta:hover {
    filter: brightness(1.08);
    box-shadow: 0 1px 0 rgba(255,255,255,0.12) inset, 0 6px 20px -2px rgba(90, 110, 30, 0.50);
    transform: translateY(-1px);
  }

  .nav-cta:active {
    transform: translateY(0px) scale(0.98);
    filter: brightness(0.96);
  }

  /* ── Hamburger ── */
  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    border-radius: 4px;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .nav-burger:hover {
    background: rgba(30, 42, 14, 0.06);
  }

  .nav-burger-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--texte);
    border-radius: 2px;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
    transform-origin: center;
  }

  .nav-burger.is-open .nav-burger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger.is-open .nav-burger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-burger.is-open .nav-burger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Menu mobile overlay ── */
  .nav-mobile-menu {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 99;
    background: var(--fond);
    border-top: 1px solid var(--border);
    flex-direction: column;
    padding: 2rem 24px 3rem;
    gap: 0;
    overflow-y: auto;
  }

  .nav-mobile-menu.is-open {
    display: flex;
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .nav-mobile-link {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--texte);
    text-decoration: none;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .nav-mobile-link:hover {
    color: var(--olive);
  }

  .nav-mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(160deg, #8A9E42 0%, #6B7C32 100%);
    color: var(--fond);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 6px;
    box-shadow: 0 4px 20px -4px rgba(90, 110, 30, 0.45);
    transition: filter 0.18s ease;
  }

  .nav-mobile-cta:hover {
    filter: brightness(1.08);
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 0 20px;
    }

    .nav-links {
      display: none;
    }

    .nav-cta-group {
      display: none;
    }

    .nav-burger {
      display: flex;
    }
  }
</style>

<script>
  const header     = document.getElementById('site-header');
  const burger     = document.getElementById('nav-burger');
  const mobileMenu = document.getElementById('nav-mobile-menu');
  const THRESHOLD  = 40;

  // Scroll state
  function onScroll() {
    if (window.scrollY > THRESHOLD) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu toggle
  function toggleMenu(open) {
    burger.classList.toggle('is-open', open);
    mobileMenu.classList.toggle('is-open', open);
    burger.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('is-open');
    toggleMenu(!isOpen);
  });

  // Fermer le menu au clic sur un lien
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });

  // Fermer si on resize au-dessus du breakpoint
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) toggleMenu(false);
  });
</script>
