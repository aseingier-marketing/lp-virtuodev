---
import Confirmation from './Confirmation.astro';
---
<section id="section-callback" class="section-dark section-pad" style="background:#0C1222;border-top:1px solid rgba(29,95,191,0.15);">
  <div class="section-inner" style="max-width:520px;">

    <div class="gs-hidden" data-gs="s9" data-gs-delay="0" style="background:#FFFFFF;border:1px solid var(--border-light);border-radius:16px;padding:40px 32px;box-shadow:0 20px 40px rgba(0,0,0,0.15);">

      <div id="offer-form-container">
        <div style="text-align:center;margin-bottom:28px;">
          <div style="display:inline-flex;align-items:center;gap:7px;background:rgba(29,95,191,0.1);border:1px solid rgba(29,95,191,0.25);border-radius:999px;padding:5px 14px;margin-bottom:16px;">
            <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#1D5FBF;flex-shrink:0;"></span>
            <span style="font-size:12px;font-weight:600;letter-spacing:0.02em;"><span id="form-count" style="color:#111827;font-weight:700;">—</span><span style="color:#1D5FBF;"> / 100 entreprises fondatrices</span></span>
          </div>
          <h2 style="font-family:var(--font-display);font-weight:700;font-size:clamp(20px,2.5vw,24px);color:var(--text-light-primary);letter-spacing:-0.02em;">Rejoindre les entreprises fondatrices</h2>
          <p style="font-size:14px;color:var(--text-light-secondary);margin-top:10px;line-height:1.55;">Les 100 premi&egrave;res entreprises acc&egrave;dent &agrave; l'offre exclusive avant son ouverture publique.</p>
        </div>

        <div style="display:flex;align-items:center;gap:10px;background:rgba(29,95,191,0.06);border:1px solid rgba(29,95,191,0.15);border-radius:10px;padding:12px 16px;margin-bottom:20px;">
          <span style="font-size:18px;flex-shrink:0;">&#128222;</span>
          <span style="font-size:13px;color:var(--text-light-secondary);line-height:1.5;">Appel de qualification de <strong style="color:var(--text-light-primary);">15 minutes</strong> pour valider votre acc&egrave;s.</span>
        </div>

        <div style="display:flex;flex-direction:column;gap:16px;">
          <div>
            <label class="form-label">Pr&eacute;nom <span style="color:#ef4444;">*</span></label>
            <input type="text" class="form-input" id="offer-prenom" placeholder="Votre pr&eacute;nom" required style="color:var(--text-light-primary);">
          </div>
          <div>
            <label class="form-label">Nom <span style="color:#ef4444;">*</span></label>
            <input type="text" class="form-input" id="offer-nom" placeholder="Votre nom" required style="color:var(--text-light-primary);">
          </div>
          <div>
            <label class="form-label">Soci&eacute;t&eacute; <span style="color:#ef4444;">*</span></label>
            <input type="text" class="form-input" id="offer-societe" placeholder="Nom de votre soci&eacute;t&eacute;" required style="color:var(--text-light-primary);">
          </div>
          <div>
            <label class="form-label">E-mail professionnel <span style="color:#ef4444;">*</span></label>
            <input type="email" class="form-input" id="offer-email" placeholder="votre@entreprise.com" required style="color:var(--text-light-primary);">
          </div>
          <div>
            <label class="form-label">T&eacute;l&eacute;phone <span style="color:#ef4444;">*</span></label>
            <input type="tel" class="form-input" id="offer-tel" placeholder="06 00 00 00 00" required style="color:var(--text-light-primary);">
          </div>
          <div>
            <label class="form-label">Message <span style="font-size:12px;color:var(--text-light-muted);font-weight:400;">(optionnel)</span></label>
            <textarea class="form-input" id="offer-message" placeholder="Parlez-nous de votre activit&eacute;..." rows="3" style="color:var(--text-light-primary);resize:vertical;min-height:80px;"></textarea>
          </div>

          <!-- Honeypot anti-spam (invisible pour les humains) -->
          <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
            <input type="text" id="offer-trap" tabindex="-1" autocomplete="off">
          </div>

          <div style="margin-top:4px;">
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;">
              <input type="checkbox" id="offer-consent" required style="margin-top:4px;accent-color:var(--accent);">
              <span style="font-size:13px;color:var(--text-light-secondary);line-height:1.5;">J'accepte d'&ecirc;tre contact&eacute; par t&eacute;l&eacute;phone. <span style="color:var(--danger);">*</span></span>
            </label>
          </div>

          <!-- Message d'erreur -->
          <div id="offer-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;font-size:13px;color:#dc2626;line-height:1.5;"></div>

          <button id="offer-submit-btn" class="btn-primary btn-primary-accent btn-primary-big" style="width:100%;margin-top:8px;" onclick="submitOfferForm()">
            Demander sa place &rarr;
          </button>

          <div style="display:flex;flex-direction:column;gap:8px;margin-top:12px;align-items:center;">
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="color:var(--success);font-size:13px;flex-shrink:0;">&#10003;</span>
              <span style="font-size:13px;color:var(--text-light-secondary);font-weight:400;">Aucun engagement.</span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="color:var(--success);font-size:13px;flex-shrink:0;">&#10003;</span>
              <span style="font-size:13px;color:var(--text-light-secondary);font-weight:400;">Nous v&eacute;rifions simplement si le syst&egrave;me correspond &agrave; votre activit&eacute;.</span>
            </div>
          </div>
          <p style="font-size:13px;color:var(--text-light-muted);margin-top:16px;text-align:center;line-height:1.5;">Vous pr&eacute;f&eacute;rez r&eacute;server directement un &eacute;change ?<br><a href="https://cal.com/a.seingier-virtuodev/15min" target="_blank" rel="noopener" style="color:var(--text-light-secondary);text-decoration:underline;text-underline-offset:3px;">Acc&eacute;dez &agrave; notre calendrier</a></p>
        </div>
      </div>

      <Confirmation />

    </div>

  </div>
</section>

<script>
  // Capture des UTM depuis l'URL au chargement
  function getUTMParams() {
    const p = new URLSearchParams(window.location.search);
    return {
      utm_source:   p.get('utm_source')   ?? '',
      utm_medium:   p.get('utm_medium')   ?? '',
      utm_campaign: p.get('utm_campaign') ?? '',
    };
  }

  // Détection de la source (referrer ou paramètre UTM)
  function detectSource(): string {
    const utm = new URLSearchParams(window.location.search).get('utm_source');
    if (utm) return utm;
    const ref = document.referrer;
    if (!ref) return 'direct';
    try {
      return new URL(ref).hostname;
    } catch {
      return 'direct';
    }
  }

  async function submitOfferForm() {
    const get = (id: string) => document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;

    const prenom  = get('offer-prenom').value.trim();
    const nom     = get('offer-nom').value.trim();
    const societe = get('offer-societe').value.trim();
    const email   = get('offer-email').value.trim();
    const tel     = get('offer-tel').value.trim();
    const message = get('offer-message').value.trim();
    const _trap   = get('offer-trap').value;
    const consent = (document.getElementById('offer-consent') as HTMLInputElement).checked;

    const errorEl = document.getElementById('offer-error')!;
    const btn     = document.getElementById('offer-submit-btn') as HTMLButtonElement;

    // Reset visuel
    errorEl.style.display = 'none';
    document.querySelectorAll('.form-input').forEach(el => (el as HTMLElement).style.borderColor = '');

    // Validation client
    let hasError = false;
    if (!prenom)  { get('offer-prenom').style.borderColor  = '#ef4444'; hasError = true; }
    if (!nom)     { get('offer-nom').style.borderColor     = '#ef4444'; hasError = true; }
    if (!societe) { get('offer-societe').style.borderColor = '#ef4444'; hasError = true; }
    if (!email)   { get('offer-email').style.borderColor   = '#ef4444'; hasError = true; }
    if (!tel)     { get('offer-tel').style.borderColor     = '#ef4444'; hasError = true; }
    if (!consent) {
      (document.getElementById('offer-consent')!.closest('label') as HTMLElement).style.color = '#ef4444';
      hasError = true;
    }
    if (hasError) return;

    // État loading
    btn.disabled = true;
    btn.textContent = 'Envoi en cours…';

    const utm = getUTMParams();

    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prenom, nom, societe, email, tel, message,
          source: detectSource(),
          _trap,
          ...utm,
        }),
      });

      const data = await res.json();

      if (!res.ok || !data.success) {
        errorEl.textContent = data.error ?? 'Une erreur est survenue. Réessayez.';
        errorEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Demander sa place →';
        return;
      }

      // Succès → reset + redirection
      ['offer-prenom','offer-nom','offer-societe','offer-email','offer-tel','offer-message'].forEach(id => {
        (document.getElementById(id) as HTMLInputElement).value = '';
      });
      (document.getElementById('offer-consent') as HTMLInputElement).checked = false;

      window.location.href = '/merci';

    } catch {
      errorEl.textContent = 'Impossible d\'envoyer le formulaire. Vérifiez votre connexion.';
      errorEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Demander sa place →';
    }
  }

  // Reset couleur bordure au focus
  document.querySelectorAll('.form-input').forEach(input => {
    input.addEventListener('focus', () => { (input as HTMLElement).style.borderColor = ''; });
  });

  window.submitOfferForm = submitOfferForm;

  // Compteur depuis Notion
  fetch('/api/count')
    .then(r => r.json())
    .then(d => {
      const el = document.getElementById('form-count');
      if (el && typeof d.count === 'number') {
        el.textContent = String(d.count);
        el.setAttribute('style', 'color:#111827;font-weight:700;');
      }
    })
    .catch(() => {});
</script>
