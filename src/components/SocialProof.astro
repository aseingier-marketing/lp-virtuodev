---
---

<!-- Section tall : crée l'espace de scroll (300vh) -->
<section class="pq-section" id="section-pour-qui">

  <!-- Conteneur sticky : reste épinglé à 100vh pendant tout le scroll -->
  <div class="pq-sticky-container" id="pq-container">

    <!-- Barre de progression latérale -->
    <div class="pq-progress-bar" aria-hidden="true">
      <div class="pq-progress-line">
        <div class="pq-progress-dot" id="pq-dot"></div>
      </div>
    </div>

    <!-- Titre -->
    <div class="pq-title-area">
      <div class="pq-inner">

        <div class="pq-badge-wrap gs-hidden" data-gs="s2b" data-gs-delay="0">
          <span class="pq-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span>Pour qui</span>
          </span>
        </div>

        <h2 class="pq-heading gs-hidden" data-gs="s2b" data-gs-delay="0.08">
          Deux profils, une m&ecirc;me r&eacute;alit&eacute;&nbsp;:<br>des devis envoy&eacute;s qui ne signent pas
        </h2>

        <p class="pq-subhead gs-hidden" data-gs="s2b" data-gs-delay="0.14">
          Virtuodev r&eacute;pond aux besoins des <strong>professionnels</strong> qui cherchent &agrave; convertir plus de devis &mdash; sans changer leur fa&ccedil;on de travailler.
        </p>

      </div>
    </div>

    <!-- Pill switcher -->
    <div class="pq-switcher-wrap">
      <div class="pq-switcher">
        <button class="pq-sw-item pq-sw-active" id="pq-sw-0" aria-label="Profil B2C">
          <span class="pq-sw-dot pq-sw-dot-b2c"></span>Artisans &amp; prestataires
        </button>
        <button class="pq-sw-item" id="pq-sw-1" aria-label="Profil B2B">
          <span class="pq-sw-dot pq-sw-dot-b2b"></span>Agences &amp; entreprises B2B
        </button>
      </div>
    </div>

    <!-- Zone des cartes empilées -->
    <div class="pq-cards-wrapper">
      <div class="pq-inner pq-inner-cards">
        <div class="pq-stack">

          <!-- Carte B2C bleue (base) -->
          <div class="pq-card" id="pq-b2c">
            <span class="pq-num" aria-hidden="true">01</span>
            <div class="pq-left">
              <h3 class="pq-profile-title">Artisans et prestataires<br>de service</h3>
              <p class="pq-profile-desc">Vous envoyez des devis mais vous n&rsquo;avez <strong>ni le temps, ni la m&eacute;thode</strong> pour relancer sans para&icirc;tre insistant.</p>
              <button class="pq-cta" onclick="document.getElementById('section-callback').scrollIntoView({behavior:'smooth'})">
                &Ccedil;a m&rsquo;int&eacute;resse
              </button>
            </div>
            <div class="pq-right">
              <p class="pq-problem">Vous g&eacute;rez clients, projets et administratif &mdash; sans savoir si vos prospects attendent juste un signe de votre part.</p>
              <div class="pq-two-cols">
                <div class="pq-col">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.5 16.5c-1.5 1.5-1.5 4 0 4s2.5-1.5 4 0"/>
                    <path d="M12 2C8 5.5 7 9.5 8 13.5l6 2c4-2.5 6.5-6 6-10.5C17 2.5 14.5 2 12 2z"/>
                    <circle cx="15.5" cy="8.5" r="1.2" fill="#2563EB" stroke="none"/>
                  </svg>
                  <h4 class="pq-col-title">Ce que Virtuodev apporte</h4>
                  <ul class="pq-bullets">
                    <li><span class="pq-dot"></span><span>Des relances automatiques pour <strong>ceux qui n&rsquo;osent pas insister</strong>.</span></li>
                    <li><span class="pq-dot"></span><span>Une s&eacute;quence calibr&eacute;e pour <strong>ceux qui ne savent pas quoi &eacute;crire</strong>.</span></li>
                    <li><span class="pq-dot"></span><span>Un suivi jusqu&rsquo;&agrave; la signature pour <strong>ceux qui veulent des r&eacute;sultats</strong>.</span></li>
                  </ul>
                </div>
                <div class="pq-col">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
                  </svg>
                  <h4 class="pq-col-title">B&eacute;n&eacute;fice concret</h4>
                  <p class="pq-col-body">Vous <strong>convertissez plus de prospects</strong> sans passer vos soir&eacute;es &agrave; relancer manuellement.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Carte B2B jaune (par-dessus, animée) -->
          <div class="pq-card pq-card-b2b" id="pq-b2b" aria-hidden="true">
            <span class="pq-num" aria-hidden="true">02</span>
            <div class="pq-left">
              <h3 class="pq-profile-title">Agences et entreprises<br>de service B2B</h3>
              <p class="pq-profile-desc">Vous envoyez des devis mais vous n&rsquo;avez <strong>ni le temps, ni la m&eacute;thode</strong> pour assurer un suivi professionnel.</p>
              <button class="pq-cta pq-cta-b2b" onclick="document.getElementById('section-callback').scrollIntoView({behavior:'smooth'})">
                &Ccedil;a m&rsquo;int&eacute;resse
              </button>
            </div>
            <div class="pq-right">
              <p class="pq-problem">Vous g&eacute;rez missions, &eacute;quipes et prospection &mdash; sans savoir si vos prospects ont simplement oubli&eacute; de vous r&eacute;pondre.</p>
              <div class="pq-two-cols">
                <div class="pq-col">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4.5 16.5c-1.5 1.5-1.5 4 0 4s2.5-1.5 4 0"/>
                    <path d="M12 2C8 5.5 7 9.5 8 13.5l6 2c4-2.5 6.5-6 6-10.5C17 2.5 14.5 2 12 2z"/>
                    <circle cx="15.5" cy="8.5" r="1.2" fill="#292524" stroke="none"/>
                  </svg>
                  <h4 class="pq-col-title">Ce que Virtuodev apporte</h4>
                  <ul class="pq-bullets">
                    <li><span class="pq-dot pq-dot-b2b"></span><span>Des relances automatiques pour <strong>ceux qui jonglent entre plusieurs dossiers</strong>.</span></li>
                    <li><span class="pq-dot pq-dot-b2b"></span><span>Une s&eacute;quence calibr&eacute;e pour <strong>ceux qui veulent rester professionnels</strong>.</span></li>
                    <li><span class="pq-dot pq-dot-b2b"></span><span>Un suivi jusqu&rsquo;&agrave; la signature pour <strong>ceux qui veulent des r&eacute;sultats</strong>.</span></li>
                  </ul>
                </div>
                <div class="pq-col">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#292524" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
                  </svg>
                  <h4 class="pq-col-title">B&eacute;n&eacute;fice concret</h4>
                  <p class="pq-col-body">Vous <strong>transformez plus de prospects en clients</strong> sans alourdir votre charge commerciale.</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  const section   = document.getElementById('section-pour-qui');
  const container = document.getElementById('pq-container');
  const b2c       = document.getElementById('pq-b2c');
  const b2b       = document.getElementById('pq-b2b');
  const dot       = document.getElementById('pq-dot');
  const sw0       = document.getElementById('pq-sw-0');
  const sw1       = document.getElementById('pq-sw-1');

  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
  function eio(t) { return t < .5 ? 2*t*t : -1+(4-2*t)*t; }

  function tick() {
    const rect    = section.getBoundingClientRect();
    const total   = section.offsetHeight - window.innerHeight;
    const scrolled = -rect.top;
    const raw     = clamp(scrolled / total, 0, 1);

    // Animation carte B2B : démarre à 25%, finit à 65%
    const p = eio(clamp((raw - 0.25) / 0.40, 0, 1));

    // B2B : monte + scale
    b2b.style.transform = `translateY(${(1 - p) * 108}%) scale(${0.965 + p * 0.035})`;
    b2b.setAttribute('aria-hidden', p < 0.5 ? 'true' : 'false');

    // B2C : s'estompe
    b2c.style.opacity   = String(1 - p * 0.55);

    // Fond : blanc → crème (#FFF8E7)
    const g = Math.round(255 - p * 7);
    const bl = Math.round(255 - p * 24);
    section.style.backgroundColor = `rgb(255,${g},${bl})`;
    container.style.backgroundColor = `rgb(255,${g},${bl})`;

    // Curseur de progression
    dot.style.top = (raw * 76) + '%';

    // Pill switcher
    const b2bActive = p > 0.5;
    sw0.classList.toggle('pq-sw-active', !b2bActive);
    sw1.classList.toggle('pq-sw-active',  b2bActive);
  }

  window.addEventListener('scroll', tick, { passive: true });
  tick();
})();
</script>

<style>
  /* ──────────────────────────────────────────
     Section — tall pour créer l'espace scroll
  ────────────────────────────────────────── */
  .pq-section {
    min-height: 280vh;
    position: relative;
    background: #fff;
    padding-bottom: 80px;
  }

  /* ──────────────────────────────────────────
     Conteneur sticky 100vh
     overflow:hidden clippe la carte B2B animée
     (pas de pb de stickiness : overflow sur soi-même est ok)
  ────────────────────────────────────────── */
  .pq-sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
  }

  .pq-inner {
    max-width: 1340px;
    margin: 0 auto;
    padding: 0 64px;
    text-align: center;
  }

  /* ──────────────────────────────────────────
     Barre de progression latérale
  ────────────────────────────────────────── */
  .pq-progress-bar {
    position: absolute;
    left: 32px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
  }
  .pq-progress-line {
    width: 2px;
    height: 90px;
    background: rgba(0,0,0,0.08);
    border-radius: 2px;
    position: relative;
  }
  .pq-progress-dot {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #1D5FBF;
    box-shadow: 0 0 0 3px rgba(29,95,191,0.15);
    transition: top 0.12s linear;
  }

  /* ──────────────────────────────────────────
     Titre
  ────────────────────────────────────────── */
  .pq-title-area {
    flex-shrink: 0;
    padding: 44px 0 10px;
  }
  .pq-badge-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 18px;
  }
  .pq-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-dim);
    border: 1px solid var(--accent-border);
    border-radius: 100px;
    padding: 6px 14px;
    font-family: var(--font-body);
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .pq-heading {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(26px, 3vw, 44px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-light-primary);
    margin: 0 auto 12px;
    max-width: 820px;
  }
  .pq-subhead {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-light-secondary);
    line-height: 1.65;
    margin: 0 auto;
    max-width: 480px;
  }
  .pq-subhead strong { color: var(--text-light-primary); font-weight: 600; }

  /* ──────────────────────────────────────────
     Pill switcher
  ────────────────────────────────────────── */
  .pq-switcher-wrap {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    padding: 14px 0 28px;
  }
  .pq-switcher {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    background: rgba(0,0,0,0.05);
    border-radius: 100px;
    padding: 3px;
  }
  .pq-sw-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 6px 15px;
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: rgba(0,0,0,0.4);
    background: transparent;
    border: none;
    cursor: default;
    transition: background 0.35s ease, color 0.35s ease, box-shadow 0.35s ease;
  }
  .pq-sw-item.pq-sw-active {
    background: #FFFFFF;
    color: var(--text-light-primary);
    box-shadow: 0 1px 5px rgba(0,0,0,0.10);
  }
  .pq-sw-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: opacity 0.35s ease;
    opacity: 0.3;
  }
  .pq-sw-item.pq-sw-active .pq-sw-dot { opacity: 1; }
  .pq-sw-dot-b2c { background: #2563EB; }
  .pq-sw-dot-b2b { background: #292524; }

  /* ──────────────────────────────────────────
     Zone cartes
  ────────────────────────────────────────── */
  .pq-cards-wrapper {
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: flex-start;
    padding-top: 16px;
    padding-bottom: 52px;
  }
  .pq-inner-cards {
    text-align: left;
    width: 100%;
  }
  .pq-stack {
    position: relative;
    width: 100%;
  }

  /* ──────────────────────────────────────────
     Cartes
  ────────────────────────────────────────── */
  .pq-card {
    background: #EEF4FF;
    border: 1px solid rgba(29,95,191,0.12);
    border-radius: 22px;
    padding: 36px 48px;
    display: grid;
    grid-template-columns: 270px 1fr;
    gap: 64px;
    align-items: start;
    text-align: left;
    box-shadow: 0 4px 20px rgba(29,95,191,0.07);
    position: relative;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
    will-change: opacity;
  }
  .pq-card-b2b {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: #FFFBEB;
    border-color: rgba(180,140,60,0.15);
    box-shadow: 0 16px 52px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
    transform: translateY(108%) scale(0.965);
    transform-origin: bottom center;
    will-change: transform;
    z-index: 2;
  }

  /* Numéros décoratifs */
  .pq-num {
    position: absolute;
    top: 12px;
    right: 28px;
    font-family: var(--font-display);
    font-size: clamp(64px, 8vw, 110px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.05em;
    color: rgba(0,0,0,0.042);
    pointer-events: none;
    user-select: none;
  }

  /* ──────────────────────────────────────────
     Contenu cartes
  ────────────────────────────────────────── */
  .pq-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pq-profile-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(22px, 2.4vw, 30px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-light-primary);
    margin: 0;
  }
  .pq-profile-desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-light-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .pq-profile-desc strong { color: var(--text-light-primary); font-weight: 600; }

  .pq-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 11px 22px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    border: none;
    background: var(--accent);
    color: #fff;
    transition: background .2s, transform .2s, box-shadow .2s;
    box-shadow: 0 8px 20px rgba(29,95,191,0.30);
    margin-top: 4px;
  }
  .pq-cta:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 12px 28px rgba(29,95,191,0.40); }
  .pq-cta-b2b { background: #1A1A1A; box-shadow: 0 8px 20px rgba(0,0,0,0.18); }
  .pq-cta-b2b:hover { background: #333; box-shadow: 0 12px 28px rgba(0,0,0,0.28); }

  .pq-right { display: flex; flex-direction: column; gap: 22px; }
  .pq-problem {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--text-light-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .pq-two-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  .pq-col { display: flex; flex-direction: column; gap: 10px; }
  .pq-col-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--text-light-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .pq-bullets { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .pq-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-family: var(--font-body);
    font-size: 13.5px;
    color: var(--text-light-secondary);
    line-height: 1.6;
  }
  .pq-bullets li strong { color: var(--text-light-primary); font-weight: 600; }
  .pq-dot {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #2563EB;
    opacity: 0.5;
    margin-top: 7px;
  }
  .pq-dot-b2b { background: #292524; opacity: 0.45; }
  .pq-col-body {
    font-family: var(--font-body);
    font-size: 13.5px;
    color: var(--text-light-secondary);
    line-height: 1.65;
    margin: 0;
  }
  .pq-col-body strong { color: var(--text-light-primary); font-weight: 600; }

  /* ──────────────────────────────────────────
     Mobile
  ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .pq-section   { min-height: auto; }
    .pq-sticky-container { position: relative; height: auto; overflow: visible; }
    .pq-progress-bar { display: none; }
    .pq-title-area { padding: 64px 0 16px; }
    .pq-inner { padding: 0 20px; }
    .pq-card { grid-template-columns: 1fr; gap: 24px; padding: 28px 22px; }
    .pq-card-b2b {
      position: relative;
      top: unset; left: unset; right: unset;
      transform: none !important;
      margin-top: 20px;
    }
    .pq-two-cols { grid-template-columns: 1fr; gap: 18px; }
    .pq-num { font-size: 52px; }
  }
</style>
