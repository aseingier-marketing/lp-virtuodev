---
---
<!-- Section 2B — Pour qui est ce système (fond clair) -->
<section class="section-light section-pad" style="background:#FFFFFF;border-top:none;">
  <div class="section-inner">

    <div class="gs-hidden" data-gs="s2b" data-gs-delay="0" style="display:flex;justify-content:center;margin-bottom:20px;">
      <div style="display:inline-flex;align-items:center;gap:9px;background:linear-gradient(180deg,rgba(59,130,246,0.08) 0%,rgba(59,130,246,0.04) 100%);border:1px solid rgba(59,130,246,0.28);border-radius:100px;padding:8px 18px;box-shadow:0 0 0 1px rgba(59,130,246,0.06),0 0 24px rgba(59,130,246,0.12);">
        <span style="width:18px;height:18px;border-radius:999px;background:rgba(59,130,246,0.14);border:1px solid rgba(96,165,250,0.28);display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        <span style="font-family:var(--font-body);font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#2563EB;">Pour qui</span>
      </div>
    </div>
    <h2 class="h1 gs-hidden" data-gs="s2b" data-gs-delay="0.1" style="color:var(--text-light-primary);max-width:680px;margin-left:auto;margin-right:auto;text-align:center;">Con&ccedil;u pour les entreprises B2C qui envoient des devis</h2>

    <!-- Secteurs chips — style premium light -->
    <div class="gs-hidden" data-gs="s2b" data-gs-delay="0.2" style="display:flex;flex-wrap:wrap;justify-content:center;gap:10px;max-width:680px;margin:28px auto 0 auto;">
      <div class="sector-chip">
        <span class="sector-chip-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1D5FBF" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
        R&eacute;novation
      </div>
      <div class="sector-chip">
        <span class="sector-chip-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1D5FBF" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
        Habitat
      </div>
      <div class="sector-chip">
        <span class="sector-chip-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1D5FBF" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
        &Eacute;quipement
      </div>
      <div class="sector-chip">
        <span class="sector-chip-icon"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1D5FBF" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
        Services &agrave; domicile
      </div>
      <div class="sector-chip sector-chip--accent">
        <span class="sector-chip-icon sector-chip-icon--accent"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1D5FBF" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg></span>
        Prestations B2C
      </div>
    </div>
    <style>
      .sector-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 40px;
        padding: 0 16px;
        border-radius: 999px;
        background: #FFFFFF;
        border: 1px solid rgba(29,95,191,0.18);
        color: var(--text-light-primary);
        font-size: 13.5px;
        font-weight: 500;
        box-shadow: 0 1px 4px rgba(29,95,191,0.07), 0 2px 12px rgba(0,0,0,0.04);
        transition: all 0.22s ease;
        cursor: default;
        letter-spacing: -0.01em;
      }
      .sector-chip:hover {
        transform: translateY(-2px);
        border-color: rgba(29,95,191,0.32);
        box-shadow: 0 4px 16px rgba(29,95,191,0.12), 0 2px 8px rgba(0,0,0,0.06);
      }
      .sector-chip--accent {
        background: rgba(29,95,191,0.06);
        border-color: rgba(29,95,191,0.28);
        color: var(--accent);
        font-weight: 600;
      }
      .sector-chip-icon {
        width: 20px;
        height: 20px;
        border-radius: 999px;
        background: rgba(29,95,191,0.10);
        border: 1px solid rgba(29,95,191,0.18);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .sector-chip-icon--accent {
        background: rgba(29,95,191,0.14);
        border-color: rgba(29,95,191,0.28);
      }
    </style>

    <p class="gs-hidden" data-gs="s2b" data-gs-delay="0.25" style="font-size:15.5px;color:var(--text-light-primary);font-weight:500;line-height:1.65;max-width:560px;margin:16px auto 0 auto;text-align:center;">
      Si vous envoyez des devis &agrave; des particuliers, vous &ecirc;tes probablement concern&eacute;.
    </p>

    <!-- Avant / Après — cards comparaison -->
    <div class="gs-hidden" data-gs="s2b" data-gs-delay="0.3" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:56px;">
      <!-- Avant — border rouge léger -->
      <div class="compare-box" style="background:#FFFFFF;border:1px solid rgba(220,38,38,0.30);border-radius:16px;overflow:hidden;">
        <div class="compare-box-header" style="background:rgba(220,38,38,0.07);padding:18px 24px;display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:-0.01em;color:#991B1B;">
          <span style="width:22px;height:22px;border-radius:50%;background:rgba(220,38,38,0.14);color:#DC2626;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">&#10005;</span>
          La situation la plus fr&eacute;quente
        </div>
        <div class="compare-box-body">
          <div class="compare-line" style="color:var(--text-light-secondary);border-bottom:1px solid var(--border-light);"><span class="compare-x">&#10005;</span><span>Vous envoyez des devis chaque semaine</span></div>
          <div class="compare-line" style="color:var(--text-light-secondary);border-bottom:1px solid var(--border-light);"><span class="compare-x">&#10005;</span><span>Certains prospects ne r&eacute;pondent plus apr&egrave;s la proposition</span></div>
          <div class="compare-line" style="color:var(--text-light-secondary);border-bottom:1px solid var(--border-light);"><span class="compare-x">&#10005;</span><span>Vos relances d&eacute;pendent du temps disponible dans votre journ&eacute;e</span></div>
          <div class="compare-line" style="color:var(--text-light-secondary);border-bottom:none;"><span class="compare-x">&#10005;</span><span>Une partie des devis finit simplement par &ecirc;tre oubli&eacute;e</span></div>
        </div>
      </div>
      <!-- Après — border vert léger -->
      <div class="compare-box" style="background:#FFFFFF;border:1px solid rgba(18,183,106,0.32);border-radius:16px;overflow:hidden;">
        <div class="compare-box-header" style="background:rgba(18,183,106,0.09);padding:18px 24px;display:flex;align-items:center;gap:10px;font-family:var(--font-display);font-weight:700;font-size:15px;letter-spacing:-0.01em;color:#166534;">
          <span style="width:22px;height:22px;border-radius:50%;background:rgba(18,183,106,0.18);color:#059669;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;">&#10003;</span>
          Ce que nous changeons
        </div>
        <div class="compare-box-body">
          <div class="compare-line" style="color:var(--text-light-primary);border-bottom:1px solid var(--border-light);"><span class="compare-check">&#10003;</span><span>Vos prospects re&ccedil;oivent des relances au bon moment</span></div>
          <div class="compare-line" style="color:var(--text-light-primary);border-bottom:1px solid var(--border-light);"><span class="compare-check">&#10003;</span><span>Les devis restent actifs jusqu'&agrave; la d&eacute;cision du client</span></div>
          <div class="compare-line" style="color:var(--text-light-primary);border-bottom:1px solid var(--border-light);"><span class="compare-check">&#10003;</span><span>Les relances ne d&eacute;pendent plus de votre m&eacute;moire ou de votre agenda</span></div>
          <div class="compare-line" style="color:var(--text-light-primary);border-bottom:none;"><span class="compare-check">&#10003;</span><span>Les prospects qui h&eacute;sitent continuent &agrave; recevoir des relances au bon moment</span></div>
        </div>
      </div>
    </div>

    <!-- Phrase pivot -->
    <div class="gs-hidden" data-gs="s2b" data-gs-delay="0.4" style="margin-top:48px;max-width:560px;margin-left:auto;margin-right:auto;text-align:center;">
      <p style="font-size:16px;color:var(--text-light-primary);line-height:1.65;">Dans beaucoup d'entreprises, le probl&egrave;me n'est pas le manque de devis.<br><strong>C'est le manque de suivi apr&egrave;s l'envoi.</strong></p>
    </div>

    <!-- CTA post-phrase pivot -->
    <div class="gs-hidden" data-gs="s2b" data-gs-delay="0.5" style="margin-top:28px;text-align:center;">
      <button style="display:inline-flex;align-items:center;justify-content:center;padding:14px 26px;border-radius:11px;font-family:var(--font-body);font-weight:600;font-size:16px;cursor:pointer;border:none;background:#1D5FBF;color:#FFFFFF;transition:background 0.2s ease,transform 0.2s ease,box-shadow 0.2s ease;box-shadow:0px 10px 25px rgba(29,95,191,0.35);" onclick="document.getElementById('section-callback').scrollIntoView({behavior:'smooth'})" onmouseover="this.style.background='#174EA6';this.style.transform='translateY(-2px)';this.style.boxShadow='0px 14px 32px rgba(29,95,191,0.45)'" onmouseout="this.style.background='#1D5FBF';this.style.transform='translateY(0)';this.style.boxShadow='0px 10px 25px rgba(29,95,191,0.35)'">
        Demander sa place &rarr;
      </button>
    </div>

  </div>
</section>
