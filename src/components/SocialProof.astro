---
---
<section class="pq-section" id="section-pour-qui">
  <div class="pq-inner">

    <!-- Badge — pattern identique à FounderCredibility -->
    <div class="pq-badge-wrap gs-hidden" data-gs="s2b" data-gs-delay="0">
      <span class="pq-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        <span>Pour qui</span>
      </span>
    </div>

    <!-- Titre -->
    <h2 class="pq-heading gs-hidden" data-gs="s2b" data-gs-delay="0.08">
      Deux profils, une m&ecirc;me r&eacute;alit&eacute;&nbsp;:<br>des devis envoy&eacute;s qui ne signent pas
    </h2>

    <!-- Sous-titre -->
    <p class="pq-subhead gs-hidden" data-gs="s2b" data-gs-delay="0.14">
      Virtuodev r&eacute;pond aux besoins des <strong>entreprises BTP</strong> qui cherchent &agrave; convertir plus de devis &mdash; sans changer leur fa&ccedil;on de travailler.
    </p>

    <!-- Rectangle -->
    <div class="pq-card gs-hidden" data-gs="s2b" data-gs-delay="0.22">

      <!-- Gauche -->
      <div class="pq-left">
        <h3 class="pq-profile-title">Artisans et PME<br>du b&acirc;timent</h3>
        <p class="pq-profile-desc">Vous envoyez des devis mais vous n&rsquo;avez <strong>ni le temps, ni la m&eacute;thode</strong> pour assurer le suivi.</p>
        <button class="pq-cta" onclick="document.getElementById('section-callback').scrollIntoView({behavior:'smooth'})">
          &Ccedil;a m&rsquo;int&eacute;resse
        </button>
      </div>

      <!-- Droite -->
      <div class="pq-right">

        <p class="pq-problem">Vous jonglez entre chantiers, &eacute;quipe et clients &mdash; sans savoir si vos devis sont encore r&eacute;cup&eacute;rables.</p>

        <!-- Ce que Virtuodev apporte | Bénéfice concret -->
        <div class="pq-two-cols">

          <div class="pq-col">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.5 16.5c-1.5 1.5-1.5 4 0 4s2.5-1.5 4 0"/>
              <path d="M12 2C8 5.5 7 9.5 8 13.5l6 2c4-2.5 6.5-6 6-10.5C17 2.5 14.5 2 12 2z"/>
              <circle cx="15.5" cy="8.5" r="1.2" fill="#2563EB" stroke="none"/>
            </svg>
            <h4 class="pq-col-title">Ce que Virtuodev apporte</h4>
            <ul class="pq-bullets">
              <li><span class="pq-dot"></span><span>Des relances automatiques pour <strong>ceux qui n&rsquo;ont pas le temps</strong>.</span></li>
              <li><span class="pq-dot"></span><span>Une s&eacute;quence calibr&eacute;e pour <strong>ceux qui ne savent pas comment</strong>.</span></li>
              <li><span class="pq-dot"></span><span>Un suivi jusqu&rsquo;&agrave; la signature pour <strong>ceux qui veulent des r&eacute;sultats</strong>.</span></li>
            </ul>
          </div>

          <div class="pq-col">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            <h4 class="pq-col-title">B&eacute;n&eacute;fice concret</h4>
            <p class="pq-col-body">Vous <strong>signez plus sans travailler plus</strong>, et pilotez votre activit&eacute; avec s&eacute;r&eacute;nit&eacute;.</p>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ─── Section ─── */
  .pq-section {
    background: #FFFFFF;
    padding: 100px 0 120px;
  }
  .pq-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 48px;
    text-align: center;
  }

  /* ─── Badge — même pattern que le reste du site ─── */
  .pq-badge-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }
  .pq-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-dim);
    border: 1px solid var(--accent-border);
    border-radius: 100px;
    padding: 7px 16px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  /* ─── Titre ─── */
  .pq-heading {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(30px, 3.6vw, 48px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-light-primary);
    margin: 0 auto 18px;
    max-width: 860px;
  }

  /* ─── Sous-titre ─── */
  .pq-subhead {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--text-light-secondary);
    line-height: 1.68;
    margin: 0 auto 52px;
    max-width: 500px;
  }
  .pq-subhead strong {
    color: var(--text-light-primary);
    font-weight: 600;
  }

  /* ─── Carte — couleurs du design system ─── */
  .pq-card {
    background: #EEF4FF;
    border: 1px solid rgba(29,95,191,0.12);
    border-radius: 24px;
    padding: 56px 64px;
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 80px;
    align-items: start;
    text-align: left;
    box-shadow: 0 4px 24px rgba(29,95,191,0.06);
  }

  /* ─── Colonne gauche ─── */
  .pq-left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pq-profile-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 2.6vw, 34px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-light-primary);
    margin: 0;
  }
  .pq-profile-desc {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--text-light-secondary);
    line-height: 1.7;
    margin: 0;
  }
  .pq-profile-desc strong {
    color: var(--text-light-primary);
    font-weight: 600;
  }

  /* CTA — même style que le reste du site */
  .pq-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 14px 26px;
    border-radius: 11px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    border: none;
    background: var(--accent);
    color: #FFFFFF;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0px 10px 25px rgba(29,95,191,0.35);
    margin-top: 6px;
  }
  .pq-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0px 14px 32px rgba(29,95,191,0.45);
  }

  /* ─── Colonne droite ─── */
  .pq-right {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .pq-problem {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--text-light-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* ─── 2 colonnes côte à côte ─── */
  .pq-two-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .pq-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pq-col-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15.5px;
    color: var(--text-light-primary);
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* Bullets */
  .pq-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .pq-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-light-secondary);
    line-height: 1.6;
  }
  .pq-bullets li strong {
    color: var(--text-light-primary);
    font-weight: 600;
  }
  .pq-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #2563EB;
    opacity: 0.55;
    margin-top: 6px;
  }

  /* Bénéfice */
  .pq-col-body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-light-secondary);
    line-height: 1.68;
    margin: 0;
  }
  .pq-col-body strong {
    color: var(--text-light-primary);
    font-weight: 600;
  }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .pq-section { padding: 72px 0 88px; }
    .pq-inner { padding: 0 20px; }
    .pq-heading br { display: none; }
    .pq-subhead { margin-bottom: 36px; }
    .pq-card {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 32px 24px;
    }
    .pq-two-cols {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
