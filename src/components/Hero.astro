---
---
<section class="section-dark section-pad hero-section" style="padding-top: 140px; min-height: 88vh; position: relative; overflow: hidden; background: linear-gradient(180deg, #05070B 0%, #070C16 100%);">

<style>
  .hero-postcta {
    margin-top: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .postcta-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    padding: 5px 5px 5px 16px;
    max-width: 580px;
    width: 100%;
  }

  .postcta-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 15px;
    color: #FFFFFF;
    min-width: 0;
  }

  .postcta-input::placeholder {
    color: rgba(255, 255, 255, 0.65);
  }

  .postcta-btn {
    flex-shrink: 0;
    background: #1D5FBF;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 11px 20px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0px 6px 18px rgba(29, 95, 191, 0.35);
    white-space: nowrap;
  }

  .postcta-btn:hover {
    background: #174EA6;
    box-shadow: 0px 8px 24px rgba(29, 95, 191, 0.5);
  }

  .postcta-hint {
    font-size: 13px;
    color: rgba(200, 208, 224, 0.45);
    margin: 0;
  }

  @media (max-width: 768px) {
    /* Supprime l'espace mort : min-height libre, padding réduit */
    .hero-section {
      padding-top: 100px !important;
      min-height: auto !important;
      padding-bottom: 48px !important;
    }

    .hero-video-wrap {
      margin-top: 32px !important;
    }

    /* Le sticky CTA mobile remplace ce bloc — inutile sur mobile */
    .hero-postcta { display: none; }

    .postcta-wrap {
      flex-direction: column;
      padding: 10px;
      gap: 8px;
      align-items: stretch;
      max-width: 100%;
    }

    .postcta-input {
      font-size: 16px; /* évite le zoom iOS */
      padding: 6px 4px;
    }

    .postcta-btn {
      width: 100%;
      text-align: center;
    }

    .hero-chip {
      height: auto;
      padding: 8px 12px;
      font-size: 12px;
    }

    .hero-badge-text {
      font-size: 11px !important;
    }
  }

</style>

  <!-- Halo principal centré derrière le titre -->
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:100%;height:700px;background:radial-gradient(circle at 50% 20%, rgba(29,95,191,0.25), transparent 60%);pointer-events:none;z-index:0;"></div>

  <div class="section-inner" style="position: relative; z-index: 1; text-align: center;">

    <!-- Badge chip -->
    <div class="gs-hidden" data-gs="hero" data-gs-delay="0" style="display: inline-flex; align-items: center; gap: 10px; background: rgba(29,95,191,0.12); border: 1px solid rgba(29,95,191,0.30); border-radius: 100px; padding: 8px 20px; margin: 0 auto;">
      <span style="width:6px;height:6px;background:#4D8EE8;border-radius:50%;flex-shrink:0;box-shadow:0 0 8px rgba(77,142,232,0.7);"></span>
      <span class="hero-badge-text" style="font-size: 13px; font-weight: 600; letter-spacing: 0.04em; color: #7FB3F5; text-align: center;">OFFRE R&Eacute;SERV&Eacute;E AUX <span style="color: #FFFFFF; font-weight: 700;">100</span> PREMI&Egrave;RES ENTREPRISES</span>
    </div>

    <!-- H1 -->
    <h1 class="gs-hidden" data-gs="hero" data-gs-delay="0.1" style="margin-top: 32px; max-width: 900px; margin-left: auto; margin-right: auto; font-family: var(--font-display); font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; text-align: center;">
      <span style="display: block; font-size: clamp(38px, 5.5vw, 72px); color: #FFFFFF;">Vous envoyez des devis.</span>
      <span class="hero-line2">
        <span class="hero-puis">Puis </span><span class="hero-silence">silence</span>
      </span>
    </h1>

    <style>
      .hero-line2 {
        display: block;
        font-size: clamp(38px, 5.5vw, 72px);
        overflow: visible;
      }
      .hero-puis {
        background: linear-gradient(90deg, #3B82F6, #5B9CF6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 20px rgba(59,130,246,0.2));
      }
      .hero-silence {
        display: inline-block;
        font-style: italic;
        padding-right: 0.08em;
        background: linear-gradient(100deg, #60A5FA 0%, #A8C8FF 55%, #DBEAFE 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 35px rgba(147,197,253,0.55));
      }
    </style>

    <!-- Sous-headline -->
    <p class="gs-hidden" data-gs="hero" data-gs-delay="0.2" style="margin-top: 24px; color: rgba(255,255,255,0.95); max-width: 620px; margin-left: auto; margin-right: auto; font-family: var(--font-body); font-weight: 400; font-size: clamp(17px, 2vw, 21px); line-height: 1.6;">
      Vos devis m&eacute;ritent des relances de qualit&eacute;
    </p>

    <!-- CTA -->
    <div class="gs-hidden" data-gs="hero" data-gs-delay="0.3" style="margin-top: 36px;">
      <button style="display: inline-flex; align-items: center; justify-content: center; padding: 14px 26px; border-radius: 11px; font-family: var(--font-body); font-weight: 600; font-size: 16px; cursor: pointer; border: none; background: #1D5FBF; color: #FFFFFF; transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease; box-shadow: 0px 10px 25px rgba(29,95,191,0.35);" onclick="document.getElementById('hero-video').scrollIntoView({behavior:'smooth'});" onmouseover="this.style.background='#174EA6';this.style.transform='translateY(-2px)';this.style.boxShadow='0px 14px 32px rgba(29,95,191,0.45)'" onmouseout="this.style.background='#1D5FBF';this.style.transform='translateY(0)';this.style.boxShadow='0px 10px 25px rgba(29,95,191,0.35)'">
        D&eacute;couvrir nos relances &rarr;
      </button>
      <div style="font-size: 15px; font-weight: 600; color: #FFFFFF; margin-top: 12px; letter-spacing: 0.01em;">Les relances personnalis&eacute;es que vos prospects attendent</div>
    </div>

    <!-- Trust line — chips premium glass -->
    <div class="gs-hidden" data-gs="hero" data-gs-delay="0.4" style="display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; justify-content: center;">
      <div class="hero-chip">
        <span class="hero-chip-icon-wrap">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        Accès fondateur
      </div>
      <div class="hero-chip">
        <span class="hero-chip-icon-wrap">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        Sans engagement
      </div>
      <div class="hero-chip">
        <span class="hero-chip-icon-wrap">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#60A5FA" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>
        </span>
        Offre exclusive
      </div>
    </div>

    <style>
      .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%);
        border: 1px solid rgba(96,165,250,0.22);
        color: #E5EDF8;
        font-size: 13px;
        font-weight: 500;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.28), 0 0 0 1px rgba(59,130,246,0.06), 0 0 30px rgba(59,130,246,0.10);
        transition: all 0.25s ease;
        cursor: default;
      }
      .hero-chip:hover {
        transform: translateY(-2px);
        border-color: rgba(96,165,250,0.38);
        box-shadow: 0 14px 34px rgba(0,0,0,0.32), 0 0 0 1px rgba(59,130,246,0.10), 0 0 38px rgba(59,130,246,0.16);
      }
      .hero-chip-icon-wrap {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        background: rgba(59,130,246,0.14);
        border: 1px solid rgba(96,165,250,0.20);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
    </style>

    <!-- Vidéo hero -->
    <div id="hero-video" class="gs-hidden hero-video-wrap" data-gs="hero" data-gs-delay="0.5" style="margin-top: 56px; max-width: 960px; width: 100%; margin-left: auto; margin-right: auto;">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        width="1280"
        height="720"
        style="width:100%;height:auto;display:block;border-radius:0;"
      >
        <source src="/videos/motion-hero.mp4" type="video/mp4">
      </video>
    </div>

    <!-- CTA post-vidéo -->
    <div class="gs-hidden hero-postcta" data-gs="hero" data-gs-delay="0.6">
      <div class="postcta-wrap">
        <input
          type="email"
          id="hero-email-input"
          class="postcta-input"
          placeholder="votremail@entreprise.com"
          autocomplete="email"
        />
        <button class="postcta-btn" onclick="heroScrollToForm()">
          Arr&ecirc;ter de perdre des devis &rarr;
        </button>
      </div>
      <p class="postcta-hint">Aucun engagement</p>
    </div>

    <script>
      function heroScrollToForm() {
        var email = document.getElementById('hero-email-input').value.trim();
        if (email) {
          var target = document.getElementById('offer-email');
          if (target) target.value = email;
        }
        document.getElementById('section-callback').scrollIntoView({ behavior: 'smooth' });
      }

      // Allow submit on Enter key
      document.getElementById('hero-email-input').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') heroScrollToForm();
      });
    </script>


  </div>
</section>
