---
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Reccolt — On relance. Tu récoltes.",
  description = "Reccolt récupère le chiffre d'affaires que tu as déjà gagné mais jamais encaissé. En moyenne, 20% du CA dort dans des devis jamais relancés. Rejoins l'offre fondateur.",
  ogImage = "/og-image.png",
} = Astro.props;

// URL canonique dynamique (SSR — fonctionne sur Vercel)
const ogUrl = Astro.url.href;

const schemaOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": ogUrl,
      "url": ogUrl,
      "name": title,
      "description": description,
      "inLanguage": "fr-FR"
    },
    {
      "@type": "Organization",
      "@id": `${ogUrl}/#organization`,
      "name": "Reccolt",
      "url": ogUrl,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "contact@reccolt.fr",
        "contactType": "customer service"
      }
    }
  ]
});
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="index, follow">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="apple-touch-icon" href="/images/favicon.png">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={ogUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={ogUrl}>
  <meta property="og:locale" content="fr_FR">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={schemaOrg}></script>

  <!-- Preload des fonts critiques -->
  <link rel="preload" as="font" href="/fonts/heros/texgyreheros-bold.otf" type="font/otf" crossorigin>
  <link rel="preload" as="font" href="/fonts/tiempos/TiemposText-Regular.woff2" type="font/woff2" crossorigin>

  <!-- Spectral — fallback éditorial pour les glyphes accentués absents des fonts Test -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">

  <link rel="dns-prefetch" href="https://cal.com">


</head>
<body>
  <a href="#main-content" class="skip-link">Passer au contenu principal</a>
  <div id="main-content">
    <slot />
  </div>
  <CookieBanner />
</body>
</html>
