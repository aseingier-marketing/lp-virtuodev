---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Prévente Fondateur — Système de relance automatique de devis",
  description = "On construit le système qui relance automatiquement vos devis. Pour les entreprises B2C qui envoient des devis et veulent structurer leur suivi jusqu'à la signature.",
  ogImage = "/og-image.png",
} = Astro.props;

// URL canonique dynamique (SSR — fonctionne sur Vercel)
const ogUrl = Astro.url.href;

const schemaOrg = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": ogUrl,
      "url": ogUrl,
      "name": title,
      "description": description,
      "inLanguage": "fr-FR"
    },
    {
      "@type": "Organization",
      "@id": `${ogUrl}/#organization`,
      "name": "Virtuodev",
      "url": ogUrl,
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "contact@virtuodev.com",
        "contactType": "customer service"
      }
    }
  ]
});
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="index, follow">
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="apple-touch-icon" href="/images/favicon.png">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={ogUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:url" content={ogUrl}>
  <meta property="og:locale" content="fr_FR">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={schemaOrg}></script>

  <!-- Preload des 2 fonts critiques — chargées depuis tokens.css inliné -->
  <link rel="preload" as="font" href="/fonts/pjs-latin.woff2" type="font/woff2" crossorigin>
  <link rel="preload" as="font" href="/fonts/dm-sans-latin.woff2" type="font/woff2" crossorigin>

  <!-- Preconnect Vimeo (connexion TCP+TLS anticipée, vidéo chargée au clic) -->
  <link rel="preconnect" href="https://player.vimeo.com">
  <link rel="dns-prefetch" href="https://cal.com">

  <!-- Prefetch de la page merci (chargement instantané après soumission) -->
  <link rel="prefetch" href="/merci">

  <!-- GSAP auto-hébergé (zéro CDN externe) -->
  <script defer src="/js/gsap.min.js"></script>
  <script defer src="/js/ScrollTrigger.min.js"></script>

  <!-- Analytics différés — chargés en idle pour ne pas bloquer le rendu initial -->
  <script>
    function loadAnalytics() {
      // Google Analytics 4
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      var gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-6N3P18H1QX';
      gaScript.onload = function() { gtag('config', 'G-6N3P18H1QX'); };
      document.head.appendChild(gaScript);

      // Microsoft Clarity
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,'clarity','script','vx3g2slfy8');
    }

    // requestIdleCallback si disponible, sinon après l'événement load
    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadAnalytics);
    } else {
      window.addEventListener('load', loadAnalytics);
    }
  </script>
</head>
<body>
  <slot />
</body>
</html>
