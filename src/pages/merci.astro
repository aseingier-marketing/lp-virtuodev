---
import Base from '../layouts/Base.astro';
import '../styles/tokens.css';
import '../styles/global.css';
---

<Base
  title="Votre demande a bien été envoyée"
  description="Votre demande a été reçue. Réservez maintenant un échange de 15 minutes pour vérifier votre situation et estimer votre potentiel de relance."
>
  <main class="merci-page">

    <!-- ── HERO CONFIRMATION ── -->
    <section class="merci-hero">
      <div class="merci-container">

        <div class="merci-check-icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d="M6 14.5L11.5 20L22 9" stroke="#12B76A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h1 class="merci-title">Votre demande a bien été envoyée</h1>

        <p class="merci-subtitle">
          Nous allons vous rappeler rapidement.
        </p>

      </div>
    </section>

    <!-- ── SÉPARATEUR ── -->
    <div class="merci-divider"></div>

    <!-- ── BLOC ACTION PRINCIPALE ── -->
    <section class="merci-action">
      <div class="merci-container">

        <div class="merci-action-card">

          <h2 class="merci-action-title">
            Vous souhaitez fixer un appel de 20 minutes ?
          </h2>

          <p class="merci-action-desc">
            Je te montre l'impact de Reccolt sur ton entreprise.
          </p>

          <!-- CTA PRINCIPAL -->
          <a
            href="https://cal.com/a.seingier-virtuodev/20min"
            target="_blank"
            rel="noopener noreferrer"
            class="merci-cta btn-primary btn-primary-accent btn-primary-big"
          >
            Réserver mon échange &rarr;
          </a>

        </div>


      </div>
    </section>

  </main>
</Base>

<style>
  /* ── PAGE ── */
  .merci-page {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .merci-container {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── HERO ── */
  .merci-hero {
    width: 100%;
    padding: 100px 0 56px;
    text-align: center;
  }

  .merci-check-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(18, 183, 106, 0.10);
    border: 1px solid rgba(18, 183, 106, 0.25);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
  }

  .merci-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 18px;
  }

  .merci-subtitle {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(16px, 1.8vw, 19px);
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── SÉPARATEUR ── */
  .merci-divider {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    height: 1px;
    background: var(--border);
  }

  /* ── ACTION BLOCK ── */
  .merci-action {
    width: 100%;
    padding: 56px 0 80px;
    text-align: center;
  }

  .merci-action-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px 40px;
    box-shadow: 0 2px 24px rgba(30, 42, 14, 0.06);
  }

  .merci-action-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--accent);
    margin-bottom: 16px;
  }

  .merci-action-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(22px, 3vw, 32px);
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text-primary);
    margin-bottom: 18px;
  }

  .merci-action-desc {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 32px;
  }

  /* ── CTA ── */
  .merci-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 400px;
    text-decoration: none;
  }

  /* ── MICRO-RÉASSURANCE ── */
  .merci-reassurance {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 16px;
  }

  /* ── FALLBACK ── */
  .merci-fallback {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-muted);
    margin-top: 28px;
  }

  /* ── LINE BREAK DESKTOP ONLY ── */
  .br-desktop { display: inline; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .merci-hero {
      padding: 72px 0 48px;
    }

    .merci-action {
      padding: 48px 0 64px;
    }

    .merci-action-card {
      padding: 32px 24px;
    }

    .merci-cta {
      max-width: 100%;
      width: 100%;
    }

    .br-desktop { display: none; }
  }
</style>
