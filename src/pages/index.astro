---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Testimonial from '../components/Testimonial.astro';
import SocialProof from '../components/SocialProof.astro';
import Problem from '../components/Problem.astro';
import QuizCalculator from '../components/QuizCalculator.astro';
import Solution from '../components/Solution.astro';
import FounderOffer from '../components/FounderOffer.astro';
import Objections from '../components/Objections.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';
import StickyCTAMobile from '../components/StickyCTAMobile.astro';

import '../styles/tokens.css';
import '../styles/global.css';
---

<Base
  title="Prévente Fondateur — Système de relance automatique de devis"
  description="On construit le système qui relance automatiquement vos devis. Pour les entreprises B2C qui envoient des devis et veulent structurer leur suivi jusqu'à la signature."
  ogImage="/images/og-image.png"
>
  <Nav />
  <Hero />

  <Testimonial
    name="Lo&iuml;c"
    role="B&acirc;ti Flamme"
    text="&laquo; Les devis partent, mais les relances ne suivent pas toujours. C'est l&agrave; qu'on laisse filer du chiffre. &raquo;"
    gsKey="t1"
  />

  <Problem />
  <QuizCalculator />
  <SocialProof />

  <Testimonial
    name="Samuel"
    role="Eau et Plaisir"
    text="&laquo; Je fais mes relances de devis moi-même, mais rien n'est automatisé, donc je perds du temps. &raquo;"
    gsKey="t2"
  />

  <Solution />
  <FounderOffer />
  <Objections />
  <FinalCTA />
  <Footer />

  <StickyCTAMobile />
  <Chatbot />

  <!-- GSAP scroll animations — initialized after GSAP deferred scripts load -->
  <script>
    // Wait for GSAP to be available (loaded deferred) — max 50 retries (5s)
    let gsapRetries = 0;
    function initGSAP() {
      if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
        if (++gsapRetries < 50) setTimeout(initGSAP, 100);
        return;
      }
      gsap.registerPlugin(ScrollTrigger);

      const isMobile = window.matchMedia('(max-width: 768px)').matches;

      // Scroll animations for .gs-hidden elements
      document.querySelectorAll('.gs-hidden').forEach(el => {
        const delay = parseFloat(el.dataset.gsDelay) || 0;
        gsap.to(el, {
          opacity: 1, y: 0,
          duration: isMobile ? 0.35 : 0.7,
          delay: isMobile ? 0 : delay,
          ease: 'cubic-bezier(0.22, 1, 0.36, 1)',
          scrollTrigger: { trigger: el, start: isMobile ? 'top 98%' : 'top 85%', once: true }
        });
      });

      // Stat counter animation
      document.querySelectorAll('[data-count-to]').forEach(el => {
        const target = parseInt(el.dataset.countTo);
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        ScrollTrigger.create({
          trigger: el, start: 'top 85%', once: true,
          onEnter: () => {
            gsap.to({ val: 0 }, {
              val: target, duration: 1.4, ease: 'power2.out',
              onUpdate: function() {
                el.innerHTML = prefix + Math.round(this.targets()[0].val).toLocaleString('fr-FR') + suffix;
              }
            });
          }
        });
      });

    }

    initGSAP();
  </script>
</Base>
