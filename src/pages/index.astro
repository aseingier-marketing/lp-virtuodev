---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Testimonial from '../components/Testimonial.astro';
import SocialProof from '../components/SocialProof.astro';
import Problem from '../components/Problem.astro';
import QuizCalculator from '../components/QuizCalculator.astro';
import Solution from '../components/Solution.astro';
import FounderOffer from '../components/FounderOffer.astro';
import Objections from '../components/Objections.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';

import '../styles/tokens.css';
import '../styles/global.css';
---

<Base
  title="Prévente Fondateur — Système de relance automatique de devis"
  description="On construit le système qui relance automatiquement vos devis. Pour les entreprises B2C qui envoient des devis et veulent structurer leur suivi jusqu'à la signature."
  ogImage="/images/og-image.png"
>
  <Nav />
  <Hero />
  <Testimonial
    name="Loïc"
    role="Bâti Flamme"
    text="« Les devis partent, mais les relances ne suivent pas toujours. C'est là qu'on laisse filer du chiffre. »"
    gsKey="t1"
  />

  <Problem />
  <QuizCalculator />
  <Solution />

  <Testimonial
    name="Samuel"
    role="Eau et Plaisir"
    text="« Mes relances de devis ne sont pas automatisées — je perds du temps. »"
    gsKey="t2"
  />

  <SocialProof />
  <FounderOffer />
  <Objections />
  <Footer />

  <Chatbot />

  <!-- Scroll animations — IntersectionObserver natif (remplace GSAP+ScrollTrigger, économise 113K) -->
  <script>
    const isMobile = window.matchMedia('(max-width: 768px)').matches;

    // Reveal animation pour .gs-hidden
    const revealIO = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const delay = parseFloat((el as HTMLElement).dataset.gsDelay ?? '0') || 0;
        el.style.transitionDelay = isMobile ? '0ms' : `${delay * 1000}ms`;
        el.classList.add('gs-visible');
        revealIO.unobserve(el);
      });
    }, {
      rootMargin: isMobile ? '0px 0px -2% 0px' : '0px 0px -15% 0px',
      threshold: 0,
    });
    document.querySelectorAll('.gs-hidden').forEach(el => revealIO.observe(el));

    // Compteur animé pour [data-count-to]
    function animateCounter(el: HTMLElement) {
      const target = parseInt(el.dataset.countTo ?? '0');
      const prefix = el.dataset.prefix ?? '';
      const suffix = el.dataset.suffix ?? '';
      const duration = 1400;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // easeOutCubic
        el.textContent = prefix + Math.round(eased * target).toLocaleString('fr-FR') + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
    const counterIO = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        animateCounter(entry.target as HTMLElement);
        counterIO.unobserve(entry.target);
      });
    }, { rootMargin: '0px 0px -15% 0px', threshold: 0 });
    document.querySelectorAll('[data-count-to]').forEach(el => counterIO.observe(el));
  </script>
</Base>
