</style>

<script>
  function getUTMParams() {
    const p = new URLSearchParams(window.location.search);
    return {
      utm_source:   p.get('utm_source')   ?? '',
      utm_medium:   p.get('utm_medium')   ?? '',
      utm_campaign: p.get('utm_campaign') ?? '',
    };
  }

  function detectSource() {
    const utm = new URLSearchParams(window.location.search).get('utm_source');
    if (utm) return utm;
    const ref = document.referrer;
    if (!ref) return 'direct';
    try { return new URL(ref).hostname; } catch { return 'direct'; }
  }

  const form        = document.getElementById('rc-contact-form') as HTMLFormElement;
  const prenomInput = document.getElementById('rc-prenom')  as HTMLInputElement;
  const nomInput    = document.getElementById('rc-nom')     as HTMLInputElement;
  const emailInput  = document.getElementById('rc-email')   as HTMLInputElement;
  const prenomError = document.getElementById('rc-prenom-error');
  const nomError    = document.getElementById('rc-nom-error');
  const emailError  = document.getElementById('rc-email-error');
  const successBox  = document.getElementById('rc-success');

  const isValidEmail = (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());

  function clearError(input: HTMLInputElement, errEl: HTMLElement | null) {
    input.classList.remove('error');
    errEl?.classList.remove('visible');
  }

  prenomInput.addEventListener('input', () => { if (prenomInput.value.trim()) clearError(prenomInput, prenomError); });
  nomInput.addEventListener('input',    () => { if (nomInput.value.trim())    clearError(nomInput, nomError); });
  emailInput.addEventListener('input',  () => { if (isValidEmail(emailInput.value)) clearError(emailInput, emailError); });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    let valid = true;

    if (!prenomInput.value.trim()) {
      prenomInput.classList.add('error');
      prenomError?.classList.add('visible');
      valid = false;
    }
    if (!nomInput.value.trim()) {
      nomInput.classList.add('error');
      nomError?.classList.add('visible');
      valid = false;
    }
    if (!isValidEmail(emailInput.value)) {
      emailInput.classList.add('error');
      emailError?.classList.add('visible');
      valid = false;
    }

    if (!valid) {
      form.querySelector('.error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const trap = (document.getElementById('rc-trap') as HTMLInputElement).value;
    const btn  = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours\u2026';

    try {
      const utm = getUTMParams();
      await fetch('/api/demo-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          prenom: prenomInput.value.trim(),
          nom:    nomInput.value.trim(),
          email:  emailInput.value.trim(),
          _trap:  trap,
          source: 'reccolteurs-' + detectSource(),
          ...utm,
        }),
      });
    } catch (_) {
      // Fail silently
    }

    form.style.display = 'none';
    successBox?.classList.add('visible');
  });
</script>
